#version 1.0

component{name:str,description:str,category:str,baseTier:str}:
  name: Dialog
  description: A modal dialog overlay with focus trapping.
  category: Overlay
  baseTier: OverlayBase

composition{role:str,parent:str,isComposite:bool}:
  role: Root
  parent: 
  isComposite: true
children[7]: DialogClose, DialogContent, DialogDescription, DialogFooter, DialogHeader, DialogTitle, DialogTrigger

parameters[7]{name:str,type:str,kind:str,default:str,description:str}:
  ChildContent, RenderFragment, Content, Sample Dialog content, The content to render inside the component.
  Class, string, String, , Additional CSS classes to apply to the root element.
  DefaultIsOpen, bool, Boolean, false, Initial open state for uncontrolled usage.
  IsOpen, bool, Boolean, false, Whether the overlay is open.
  IsOpenChanged, EventCallback<bool>, Event, Microsoft.AspNetCore.Components.EventCallback`1[System.Boolean], Callback for two-way binding of IsOpen.
  OnClose, EventCallback, Event, Microsoft.AspNetCore.Components.EventCallback, Callback invoked when the overlay closes.
  OnOpenChanged, EventCallback<bool>, Event, Microsoft.AspNetCore.Components.EventCallback`1[System.Boolean], Callback invoked when the open state changes.
