@page "/"
@using BlazingSpire.Demo.Components.UI

<PageTitle>BlazingSpire</PageTitle>

<div class="space-y-20 pb-16">

    <!-- Hero -->
    <div class="pt-8 space-y-6">
        <div class="space-y-4 max-w-3xl">
            <h1 class="text-5xl font-bold tracking-tight">BlazingSpire</h1>
            <p class="text-xl text-muted-foreground leading-relaxed">
                A Blazor component framework inspired by shadcn/ui. Copy-paste components,
                Tailwind CSS v4, OKLCH color system. You own the code.
            </p>
        </div>
        <div class="flex flex-wrap gap-3">
            <Button Href="/components/button">Browse Components</Button>
            <Button Variant="ButtonVariant.Outline" Href="https://github.com/Spire-Recovery-Solutions/BlazingSpire" Target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                    <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
                GitHub
            </Button>
        </div>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <Card>
            <CardHeader>
                <div class="flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                         class="h-5 w-5 text-muted-foreground">
                        <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/>
                        <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/>
                        <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>
                    </svg>
                    <div>
                        <CardTitle Class="text-2xl font-bold">47</CardTitle>
                        <p class="text-sm text-muted-foreground">Components</p>
                    </div>
                </div>
            </CardHeader>
        </Card>

        <Card>
            <CardHeader>
                <div class="flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                         class="h-5 w-5 text-muted-foreground">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                    <div>
                        <CardTitle Class="text-2xl font-bold">718</CardTitle>
                        <p class="text-sm text-muted-foreground">Tests</p>
                    </div>
                </div>
            </CardHeader>
        </Card>

        <Card>
            <CardHeader>
                <div class="flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                         class="h-5 w-5 text-muted-foreground">
                        <rect width="8" height="4" x="8" y="2" rx="1" ry="1"/>
                        <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
                    </svg>
                    <div>
                        <CardTitle Class="text-2xl font-bold">Copy</CardTitle>
                        <p class="text-sm text-muted-foreground">&amp; Paste</p>
                    </div>
                </div>
            </CardHeader>
        </Card>

        <Card>
            <CardHeader>
                <div class="flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                         class="h-5 w-5 text-muted-foreground">
                        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
                    </svg>
                    <div>
                        <CardTitle Class="text-2xl font-bold">Dark</CardTitle>
                        <p class="text-sm text-muted-foreground">Mode</p>
                    </div>
                </div>
            </CardHeader>
        </Card>
    </div>

    <!-- Preview section -->
    <div class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">See it in action</h2>
            <p class="text-sm text-muted-foreground mt-1">Components composing naturally together.</p>
        </div>

        <div class="border rounded-xl p-6 bg-muted/30">
            <Card Class="max-w-md mx-auto">
                <CardHeader>
                    <CardTitle>Create account</CardTitle>
                    <CardDescription>Enter your details to get started.</CardDescription>
                </CardHeader>
                <CardContent>
                    <div class="space-y-4">
                        <div class="space-y-1.5">
                            <Label For="preview-name">Name</Label>
                            <Input Id="preview-name" Placeholder="Jane Smith" />
                        </div>
                        <div class="space-y-1.5">
                            <Label For="preview-email">Email</Label>
                            <Input Id="preview-email" Type="email" Placeholder="jane@example.com" />
                        </div>
                        <div class="space-y-1.5">
                            <Label For="preview-role">Role</Label>
                            <Select>
                                <SelectTrigger Id="preview-role">
                                    <SelectValue Placeholder="Select a role" />
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectItem ItemValue="admin">Admin</SelectItem>
                                    <SelectItem ItemValue="member">Member</SelectItem>
                                    <SelectItem ItemValue="viewer">Viewer</SelectItem>
                                </SelectContent>
                            </Select>
                        </div>
                    </div>
                </CardContent>
                <CardFooter>
                    <div class="flex gap-2 w-full">
                        <Button Variant="ButtonVariant.Outline" Class="flex-1">Cancel</Button>
                        <Button Class="flex-1">Create</Button>
                    </div>
                </CardFooter>
            </Card>
        </div>
    </div>

    <!-- Component categories -->
    <div class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Browse by category</h2>
            <p class="text-sm text-muted-foreground mt-1">47 components across 5 categories.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <a href="/components/separator" class="block group">
                <Card Class="h-full transition-colors hover:border-foreground/30">
                    <CardHeader>
                        <div class="flex items-center gap-3">
                            <div class="p-2 rounded-md bg-muted">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                                     class="h-4 w-4">
                                    <rect width="18" height="18" x="3" y="3" rx="2"/>
                                    <path d="M3 9h18"/>
                                    <path d="M3 15h18"/>
                                </svg>
                            </div>
                            <div>
                                <CardTitle>Layout</CardTitle>
                                <CardDescription>Separators, Cards, Aspect Ratios</CardDescription>
                            </div>
                        </div>
                    </CardHeader>
                </Card>
            </a>

            <a href="/components/button" class="block group">
                <Card Class="h-full transition-colors hover:border-foreground/30">
                    <CardHeader>
                        <div class="flex items-center gap-3">
                            <div class="p-2 rounded-md bg-muted">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                                     class="h-4 w-4">
                                    <rect width="20" height="12" x="2" y="6" rx="2"/>
                                    <path d="M12 12h.01"/>
                                    <path d="M17 12h.01"/>
                                    <path d="M7 12h.01"/>
                                </svg>
                            </div>
                            <div>
                                <CardTitle>Forms</CardTitle>
                                <CardDescription>Inputs, Selects, Checkboxes</CardDescription>
                            </div>
                        </div>
                    </CardHeader>
                </Card>
            </a>

            <a href="/components/alert" class="block group">
                <Card Class="h-full transition-colors hover:border-foreground/30">
                    <CardHeader>
                        <div class="flex items-center gap-3">
                            <div class="p-2 rounded-md bg-muted">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                                     class="h-4 w-4">
                                    <path d="M3 3h18v18H3zM12 8v4M12 16h.01"/>
                                </svg>
                            </div>
                            <div>
                                <CardTitle>Data Display</CardTitle>
                                <CardDescription>Badges, Tables, Alerts</CardDescription>
                            </div>
                        </div>
                    </CardHeader>
                </Card>
            </a>

            <a href="/components/dialog" class="block group">
                <Card Class="h-full transition-colors hover:border-foreground/30">
                    <CardHeader>
                        <div class="flex items-center gap-3">
                            <div class="p-2 rounded-md bg-muted">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                                     class="h-4 w-4">
                                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                                </svg>
                            </div>
                            <div>
                                <CardTitle>Feedback</CardTitle>
                                <CardDescription>Dialogs, Toasts, Popovers</CardDescription>
                            </div>
                        </div>
                    </CardHeader>
                </Card>
            </a>

            <a href="/components/accordion" class="block group">
                <Card Class="h-full transition-colors hover:border-foreground/30">
                    <CardHeader>
                        <div class="flex items-center gap-3">
                            <div class="p-2 rounded-md bg-muted">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
                                     class="h-4 w-4">
                                    <circle cx="12" cy="12" r="10"/>
                                    <path d="M8 12h8"/>
                                    <path d="m12 16 4-4-4-4"/>
                                </svg>
                            </div>
                            <div>
                                <CardTitle>Navigation</CardTitle>
                                <CardDescription>Accordions, Tabs, Menus</CardDescription>
                            </div>
                        </div>
                    </CardHeader>
                </Card>
            </a>
        </div>
    </div>

</div>
