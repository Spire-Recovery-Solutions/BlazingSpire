    <!-- ──────────────────────────────────────────────── -->
    <!-- DATATABLE -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">DataTable</h2>
            <p class="text-sm text-muted-foreground mt-1">A generic table for typed data with column definitions, sortable headers, and custom row templates.</p>
        </div>

        <div class="space-y-3">
            <h3 class="text-lg font-medium">Payments</h3>
            <DataTable TItem="PaymentRow" Items="_payments" SortColumn="@_paymentSort" SortAscending="@_paymentSortAsc" OnSort="@(col => { _paymentSort = col; })">
                <Columns>
                    <DataTableColumn SortKey="status" Sortable>Status</DataTableColumn>
                    <DataTableColumn SortKey="email" Sortable>Email</DataTableColumn>
                    <DataTableColumn SortKey="amount" Sortable>Amount</DataTableColumn>
                </Columns>
                <RowTemplate Context="row">
                    <TableRow>
                        <TableCell>
                            <Badge Variant="@(row.Status == "Paid" ? BadgeVariant.Default : row.Status == "Pending" ? BadgeVariant.Secondary : BadgeVariant.Destructive)">
                                @row.Status
                            </Badge>
                        </TableCell>
                        <TableCell>@row.Email</TableCell>
                        <TableCell>@row.Amount.ToString("C")</TableCell>
                    </TableRow>
                </RowTemplate>
            </DataTable>
            <pre class="language-xml"><code class="language-xml">@@* Define your record *@@
@@code {
    record PaymentRow(string Status, string Email, decimal Amount);
    List&lt;PaymentRow&gt; payments = [ /* ... */ ];
}

&lt;DataTable TItem="PaymentRow" Items="payments"&gt;
    &lt;Columns&gt;
        &lt;DataTableColumn SortKey="status" Sortable&gt;Status&lt;/DataTableColumn&gt;
        &lt;DataTableColumn SortKey="email" Sortable&gt;Email&lt;/DataTableColumn&gt;
        &lt;DataTableColumn SortKey="amount" Sortable&gt;Amount&lt;/DataTableColumn&gt;
    &lt;/Columns&gt;
    &lt;RowTemplate Context="row"&gt;
        &lt;TableRow&gt;
            &lt;TableCell&gt;@@row.Status&lt;/TableCell&gt;
            &lt;TableCell&gt;@@row.Email&lt;/TableCell&gt;
            &lt;TableCell&gt;@@row.Amount.ToString("C")&lt;/TableCell&gt;
        &lt;/TableRow&gt;
    &lt;/RowTemplate&gt;
&lt;/DataTable&gt;</code></pre>
        </div>

        <div class="space-y-3">
            <h3 class="text-lg font-medium">Empty State</h3>
            <DataTable TItem="PaymentRow" Items="[]">
                <Columns>
                    <DataTableColumn>Status</DataTableColumn>
                    <DataTableColumn>Email</DataTableColumn>
                    <DataTableColumn>Amount</DataTableColumn>
                </Columns>
            </DataTable>
        </div>
    </section>

    <!-- ──────────────────────────────────────────────── -->
    <!-- CAROUSEL -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Carousel</h2>
            <p class="text-sm text-muted-foreground mt-1">A slideshow component for cycling through elements. Supports prev/next navigation and ARIA slide roles.</p>
        </div>

        <div class="space-y-3">
            <h3 class="text-lg font-medium">Default</h3>
            <div class="w-full max-w-sm mx-auto">
                <Carousel CurrentIndex="@_carouselIndex" CurrentIndexChanged="@(i => _carouselIndex = i)">
                    <CarouselContent>
                        <CarouselItem><div class="flex items-center justify-center h-32 rounded-lg bg-muted text-2xl font-bold">1</div></CarouselItem>
                        <CarouselItem><div class="flex items-center justify-center h-32 rounded-lg bg-muted text-2xl font-bold">2</div></CarouselItem>
                        <CarouselItem><div class="flex items-center justify-center h-32 rounded-lg bg-muted text-2xl font-bold">3</div></CarouselItem>
                        <CarouselItem><div class="flex items-center justify-center h-32 rounded-lg bg-muted text-2xl font-bold">4</div></CarouselItem>
                        <CarouselItem><div class="flex items-center justify-center h-32 rounded-lg bg-muted text-2xl font-bold">5</div></CarouselItem>
                    </CarouselContent>
                    <CarouselPrevious />
                    <CarouselNext />
                </Carousel>
            </div>
            <p class="text-sm text-muted-foreground text-center">Slide @(_carouselIndex + 1) of 5</p>
            <pre class="language-xml"><code class="language-xml">&lt;Carousel @@bind-CurrentIndex="carouselIndex"&gt;
    &lt;CarouselContent&gt;
        &lt;CarouselItem&gt;&lt;!-- slide 1 --&gt;&lt;/CarouselItem&gt;
        &lt;CarouselItem&gt;&lt;!-- slide 2 --&gt;&lt;/CarouselItem&gt;
        &lt;CarouselItem&gt;&lt;!-- slide 3 --&gt;&lt;/CarouselItem&gt;
    &lt;/CarouselContent&gt;
    &lt;CarouselPrevious /&gt;
    &lt;CarouselNext /&gt;
&lt;/Carousel&gt;</code></pre>
        </div>
    </section>

    <!-- ──────────────────────────────────────────────── -->
    <!-- TOAST -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Toast</h2>
            <p class="text-sm text-muted-foreground mt-1">Service-based toast notifications. Supports default and destructive variants with optional actions.</p>
        </div>

        <div class="space-y-3">
            <h3 class="text-lg font-medium">Variants</h3>
            <div class="flex flex-wrap items-center gap-4">
                <Button @onclick="ShowDefaultToast">Show Toast</Button>
                <Button Variant="ButtonVariant.Destructive" @onclick="ShowDestructiveToast">Show Error Toast</Button>
            </div>
            <pre class="language-xml"><code class="language-xml">@@inject IToastService ToastService

&lt;Button @@onclick="ShowToast"&gt;Show Toast&lt;/Button&gt;

@@code {
    private void ShowToast()
        =&gt; ToastService.Show("Event has been created", "Monday, January 3 at 6:00pm");
}</code></pre>
        </div>
    </section>

</div>

