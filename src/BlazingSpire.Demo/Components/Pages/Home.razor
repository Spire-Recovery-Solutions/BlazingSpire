                <div class="flex items-center gap-2">
                    <RadioGroupItem ItemValue="default" id="r2-default" />
                    <Label For="r2-default">Default</Label>
                </div>
                <div class="flex items-center gap-2">
                    <RadioGroupItem ItemValue="comfortable" id="r2-comfortable" />
                    <Label For="r2-comfortable">Comfortable</Label>
                </div>
                <div class="flex items-center gap-2">
                    <RadioGroupItem ItemValue="compact" id="r2-compact" />
