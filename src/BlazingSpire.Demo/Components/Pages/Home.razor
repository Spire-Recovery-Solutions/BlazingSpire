    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Calendar</h2>
            <p class="text-sm text-muted-foreground mt-1">A date picker calendar with month navigation and selectable days.</p>
        </div>

        <div class="space-y-3">
            <h3 class="text-lg font-medium">Date Picker</h3>
            <Card class="w-fit">
                <CardContent class="pt-6">
                    <Calendar @bind-SelectedDate="_calendarDate" />
                    @if (_calendarDate.HasValue)
                    {
                        <p class="text-sm text-muted-foreground mt-2 text-center">Selected: @_calendarDate.Value.ToString("MMMM d, yyyy")</p>
                    }
                </CardContent>
            </Card>
            <pre class="language-xml"><code class="language-xml">&lt;Calendar &#64;bind-SelectedDate="_selectedDate" /&gt;</code></pre>
        </div>
    </section>

    <!-- ──────────────────────────────────────────────── -->
    <!-- INPUTOTP -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">InputOTP</h2>
            <p class="text-sm text-muted-foreground mt-1">One-time password input with grouped slots and separator support.</p>
        </div>

        <!-- 6-digit OTP with two groups -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">6-Digit OTP</h3>
            <div class="flex items-center gap-2">
                <InputOTP MaxLength="6" @bind-Value="_otpValue">
                    <InputOTPGroup>
                        <InputOTPSlot Index="0" />
                        <InputOTPSlot Index="1" />
                        <InputOTPSlot Index="2" />
                    </InputOTPGroup>
                    <InputOTPSeparator />
                    <InputOTPGroup>
                        <InputOTPSlot Index="3" />
                        <InputOTPSlot Index="4" />
                        <InputOTPSlot Index="5" />
                    </InputOTPGroup>
                </InputOTP>
            </div>
            @if (!string.IsNullOrEmpty(_otpValue))
            {
                <p class="text-sm text-muted-foreground">Value: <span class="font-mono">@_otpValue</span></p>
            }
            <pre class="language-xml"><code class="language-xml">&lt;InputOTP MaxLength="6" &#64;bind-Value="_otpValue"&gt;
    &lt;InputOTPGroup&gt;
        &lt;InputOTPSlot Index="0" /&gt;
        &lt;InputOTPSlot Index="1" /&gt;
        &lt;InputOTPSlot Index="2" /&gt;
    &lt;/InputOTPGroup&gt;
    &lt;InputOTPSeparator /&gt;
    &lt;InputOTPGroup&gt;
        &lt;InputOTPSlot Index="3" /&gt;
        &lt;InputOTPSlot Index="4" /&gt;
        &lt;InputOTPSlot Index="5" /&gt;
    &lt;/InputOTPGroup&gt;
&lt;/InputOTP&gt;</code></pre>
        </div>
    </section>

