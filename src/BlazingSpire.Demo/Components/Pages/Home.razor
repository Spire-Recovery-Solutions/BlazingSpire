    <!-- SIDEBAR -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Sidebar</h2>
            <p class="text-sm text-muted-foreground mt-1">A collapsible navigation sidebar with header, content, footer, and a toggle trigger.</p>
        </div>

        <div class="space-y-3">
            <h3 class="text-lg font-medium">Collapsible sidebar</h3>
            <div class="h-64 overflow-hidden rounded-lg border">
                <Sidebar @bind-IsCollapsed="_sidebarCollapsed">
                    <SidebarHeader>
                        <SidebarTrigger />
                        @if (!_sidebarCollapsed)
                        {
                            <span class="ml-2 text-sm font-semibold">Navigation</span>
                        }
                    </SidebarHeader>
