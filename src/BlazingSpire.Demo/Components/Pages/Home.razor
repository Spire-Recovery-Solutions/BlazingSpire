@page "/"
@using BlazingSpire.Demo.Components.UI

<PageTitle>BlazingSpire</PageTitle>

<div class="space-y-16">

    <!-- Hero -->
    <div class="space-y-4">
        <h1 class="text-4xl font-bold tracking-tight">BlazingSpire</h1>
        <p class="text-lg text-muted-foreground max-w-2xl">
            A Blazor component framework inspired by shadcn/ui. Copy-paste components,
            Tailwind CSS v4, OKLCH color system. You own the code.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
            <Button>Get Started</Button>
            <Button Variant="Button.ButtonVariant.Outline">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                    <path d="M9 18c-4.51 2-5-2-7-2"/>
                </svg>
                GitHub
            </Button>
        </div>
    </div>

    <!-- ──────────────────────────────────────────────── -->
    <!-- BUTTON -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Button</h2>
            <p class="text-sm text-muted-foreground mt-1">Trigger actions and events. Supports variants, sizes, icons, and disabled states.</p>
        </div>

        <!-- Variants -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Variants</h3>
            <div class="flex flex-wrap items-center gap-4">
                <Button>Default</Button>
                <Button Variant="Button.ButtonVariant.Secondary">Secondary</Button>
                <Button Variant="Button.ButtonVariant.Destructive">Destructive</Button>
                <Button Variant="Button.ButtonVariant.Outline">Outline</Button>
                <Button Variant="Button.ButtonVariant.Ghost">Ghost</Button>
                <Button Variant="Button.ButtonVariant.Link">Link</Button>
            </div>
            <pre class="code-example"><code>&lt;Button&gt;Default&lt;/Button&gt;
&lt;Button Variant="Button.ButtonVariant.Secondary"&gt;Secondary&lt;/Button&gt;
&lt;Button Variant="Button.ButtonVariant.Destructive"&gt;Destructive&lt;/Button&gt;
&lt;Button Variant="Button.ButtonVariant.Outline"&gt;Outline&lt;/Button&gt;
&lt;Button Variant="Button.ButtonVariant.Ghost"&gt;Ghost&lt;/Button&gt;
&lt;Button Variant="Button.ButtonVariant.Link"&gt;Link&lt;/Button&gt;</code></pre>
        </div>

        <!-- Sizes -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Sizes</h3>
            <div class="flex flex-wrap items-center gap-4">
                <Button Size="Button.ButtonSize.Sm">Small</Button>
                <Button>Default</Button>
                <Button Size="Button.ButtonSize.Lg">Large</Button>
                <Button Size="Button.ButtonSize.Icon" aria-label="Settings">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                </Button>
            </div>
            <pre class="code-example"><code>&lt;Button Size="Button.ButtonSize.Sm"&gt;Small&lt;/Button&gt;
&lt;Button&gt;Default&lt;/Button&gt;
&lt;Button Size="Button.ButtonSize.Lg"&gt;Large&lt;/Button&gt;
&lt;Button Size="Button.ButtonSize.Icon" aria-label="Settings"&gt;
    @* SVG icon here *@
&lt;/Button&gt;</code></pre>
        </div>

        <!-- With Icons -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">With Icons</h3>
            <div class="flex flex-wrap items-center gap-4">
                <Button>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                    </svg>
                    Continue
                </Button>
                <Button Variant="Button.ButtonVariant.Outline">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>
                    </svg>
                    Download
                </Button>
                <Button Variant="Button.ButtonVariant.Secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
                        <polyline points="16 6 12 2 8 6"/><line x1="12" x2="12" y1="2" y2="15"/>
                    </svg>
                    Upload
                </Button>
                <Button Variant="Button.ButtonVariant.Destructive">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                        <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                    </svg>
                    Delete
                </Button>
            </div>
            <pre class="code-example"><code>&lt;Button&gt;
    &lt;svg class="h-4 w-4"&gt;...&lt;/svg&gt;
    Continue
&lt;/Button&gt;
&lt;Button Variant="Button.ButtonVariant.Destructive"&gt;
    &lt;svg class="h-4 w-4"&gt;...&lt;/svg&gt;
    Delete
&lt;/Button&gt;</code></pre>
        </div>

        <!-- Disabled -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Disabled</h3>
            <div class="flex flex-wrap items-center gap-4">
                <Button Disabled="true">Disabled</Button>
                <Button Variant="Button.ButtonVariant.Secondary" Disabled="true">Disabled Secondary</Button>
                <Button Variant="Button.ButtonVariant.Destructive" Disabled="true">Disabled Destructive</Button>
                <Button Variant="Button.ButtonVariant.Outline" Disabled="true">Disabled Outline</Button>
            </div>
            <pre class="code-example"><code>&lt;Button Disabled="true"&gt;Disabled&lt;/Button&gt;
&lt;Button Variant="Button.ButtonVariant.Outline" Disabled="true"&gt;Disabled Outline&lt;/Button&gt;</code></pre>
        </div>
    </section>

    <!-- ──────────────────────────────────────────────── -->
    <!-- BADGE -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Badge</h2>
            <p class="text-sm text-muted-foreground mt-1">Display status, labels, or counts. Small pill-shaped indicators.</p>
        </div>

        <!-- Variants -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Variants</h3>
            <div class="flex flex-wrap items-center gap-4">
                <Badge>Default</Badge>
                <Badge Variant="Badge.BadgeVariant.Secondary">Secondary</Badge>
                <Badge Variant="Badge.BadgeVariant.Destructive">Destructive</Badge>
                <Badge Variant="Badge.BadgeVariant.Outline">Outline</Badge>
            </div>
            <pre class="code-example"><code>&lt;Badge&gt;Default&lt;/Badge&gt;
&lt;Badge Variant="Badge.BadgeVariant.Secondary"&gt;Secondary&lt;/Badge&gt;
&lt;Badge Variant="Badge.BadgeVariant.Destructive"&gt;Destructive&lt;/Badge&gt;
&lt;Badge Variant="Badge.BadgeVariant.Outline"&gt;Outline&lt;/Badge&gt;</code></pre>
        </div>

        <!-- In Context -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">In Context</h3>
            <div class="space-y-4">
                <div class="flex items-center gap-3">
                    <span class="text-sm font-medium">Build status:</span>
                    <Badge>Passing</Badge>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-sm font-medium">Deployment:</span>
                    <Badge Variant="Badge.BadgeVariant.Secondary">Preview</Badge>
                    <Badge>Production</Badge>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-sm font-medium">Issues:</span>
                    <Badge Variant="Badge.BadgeVariant.Destructive">3 Critical</Badge>
                    <Badge Variant="Badge.BadgeVariant.Outline">12 Open</Badge>
                    <Badge Variant="Badge.BadgeVariant.Secondary">45 Closed</Badge>
                </div>
            </div>
            <pre class="code-example"><code>&lt;div class="flex items-center gap-3"&gt;
    &lt;span&gt;Issues:&lt;/span&gt;
    &lt;Badge Variant="Badge.BadgeVariant.Destructive"&gt;3 Critical&lt;/Badge&gt;
    &lt;Badge Variant="Badge.BadgeVariant.Outline"&gt;12 Open&lt;/Badge&gt;
    &lt;Badge Variant="Badge.BadgeVariant.Secondary"&gt;45 Closed&lt;/Badge&gt;
&lt;/div&gt;</code></pre>
        </div>

        <!-- Tag Lists -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Tag List</h3>
            <div class="flex flex-wrap gap-2">
                <Badge Variant="Badge.BadgeVariant.Outline">Blazor</Badge>
                <Badge Variant="Badge.BadgeVariant.Outline">.NET 10</Badge>
                <Badge Variant="Badge.BadgeVariant.Outline">Tailwind v4</Badge>
                <Badge Variant="Badge.BadgeVariant.Outline">OKLCH</Badge>
                <Badge Variant="Badge.BadgeVariant.Outline">WASM</Badge>
                <Badge Variant="Badge.BadgeVariant.Outline">AOT</Badge>
                <Badge Variant="Badge.BadgeVariant.Outline">shadcn/ui</Badge>
            </div>
            <pre class="code-example"><code>&lt;div class="flex flex-wrap gap-2"&gt;
    &lt;Badge Variant="Badge.BadgeVariant.Outline"&gt;Blazor&lt;/Badge&gt;
    &lt;Badge Variant="Badge.BadgeVariant.Outline"&gt;.NET 10&lt;/Badge&gt;
    &lt;Badge Variant="Badge.BadgeVariant.Outline"&gt;Tailwind v4&lt;/Badge&gt;
&lt;/div&gt;</code></pre>
        </div>
    </section>

    <!-- ──────────────────────────────────────────────── -->
    <!-- CARD -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Card</h2>
            <p class="text-sm text-muted-foreground mt-1">Structured containers for grouping related content. Composable via CardHeader, CardContent, and CardFooter.</p>
        </div>

        <!-- Basic Cards -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Basic</h3>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                <Card>
                    <CardHeader>
                        <CardTitle>Create project</CardTitle>
                        <CardDescription>Deploy your new project in one-click.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm text-muted-foreground">
                            Pre-configured with .NET 10, Tailwind CSS v4, and optimized WASM delivery.
                        </p>
                    </CardContent>
                    <CardFooter>
                        <Button>Deploy</Button>
                    </CardFooter>
                </Card>

                <Card>
                    <CardHeader>
                        <CardTitle>Components</CardTitle>
                        <CardDescription>Browse the component library.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="flex flex-wrap gap-2">
                            <Badge>Button</Badge>
                            <Badge Variant="Badge.BadgeVariant.Secondary">Card</Badge>
                            <Badge Variant="Badge.BadgeVariant.Outline">Badge</Badge>
                            <Badge Variant="Badge.BadgeVariant.Secondary">Dialog</Badge>
                            <Badge Variant="Badge.BadgeVariant.Outline">Select</Badge>
                        </div>
                    </CardContent>
                    <CardFooter>
                        <Button Variant="Button.ButtonVariant.Outline">Browse</Button>
                    </CardFooter>
                </Card>

                <Card>
                    <CardHeader>
                        <CardTitle>Documentation</CardTitle>
                        <CardDescription>Learn how to use BlazingSpire.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm text-muted-foreground">
                            Copy-paste components into your Blazor project. You own the code.
                            Customize everything.
                        </p>
                    </CardContent>
                    <CardFooter>
                        <Button Variant="Button.ButtonVariant.Ghost">Read docs</Button>
                    </CardFooter>
                </Card>
            </div>
            <pre class="code-example"><code>&lt;Card&gt;
    &lt;CardHeader&gt;
        &lt;CardTitle&gt;Create project&lt;/CardTitle&gt;
        &lt;CardDescription&gt;Deploy your new project in one-click.&lt;/CardDescription&gt;
    &lt;/CardHeader&gt;
    &lt;CardContent&gt;
        &lt;p&gt;Pre-configured with .NET 10 and Tailwind CSS v4.&lt;/p&gt;
    &lt;/CardContent&gt;
    &lt;CardFooter&gt;
        &lt;Button&gt;Deploy&lt;/Button&gt;
    &lt;/CardFooter&gt;
&lt;/Card&gt;</code></pre>
        </div>

        <!-- Stats Cards -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Stats</h3>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                <Card>
                    <CardHeader>
                        <CardDescription>Total Downloads</CardDescription>
                        <CardTitle Class="text-3xl">2,350</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-xs text-muted-foreground">+180 from last month</p>
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <CardDescription>Active Users</CardDescription>
                        <CardTitle Class="text-3xl">573</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-xs text-muted-foreground">+24 from last week</p>
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <CardDescription>Components</CardDescription>
                        <CardTitle Class="text-3xl">12</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-xs text-muted-foreground">3 new this release</p>
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <CardDescription>Lighthouse Score</CardDescription>
                        <CardTitle Class="text-3xl">100</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-xs text-muted-foreground">Performance / A11y / SEO / BP</p>
                    </CardContent>
                </Card>
            </div>
            <pre class="code-example"><code>&lt;Card&gt;
    &lt;CardHeader&gt;
        &lt;CardDescription&gt;Total Downloads&lt;/CardDescription&gt;
        &lt;CardTitle Class="text-3xl"&gt;2,350&lt;/CardTitle&gt;
    &lt;/CardHeader&gt;
    &lt;CardContent&gt;
        &lt;p class="text-xs text-muted-foreground"&gt;+180 from last month&lt;/p&gt;
    &lt;/CardContent&gt;
&lt;/Card&gt;</code></pre>
        </div>

        <!-- Notification Card -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Notifications</h3>
            <div class="max-w-md">
                <Card>
                    <CardHeader>
                        <CardTitle>Notifications</CardTitle>
                        <CardDescription>You have 3 unread messages.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="space-y-4">
                            <div class="flex items-start gap-3">
                                <span class="mt-0.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
                                <div>
                                    <p class="text-sm font-medium">New component released</p>
                                    <p class="text-xs text-muted-foreground">The Dialog component is now available.</p>
                                </div>
                                <Badge Variant="Badge.BadgeVariant.Secondary" Class="ml-auto shrink-0">1h ago</Badge>
                            </div>
                            <div class="flex items-start gap-3">
                                <span class="mt-0.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
                                <div>
                                    <p class="text-sm font-medium">Build succeeded</p>
                                    <p class="text-xs text-muted-foreground">Production deployment completed.</p>
                                </div>
                                <Badge Variant="Badge.BadgeVariant.Secondary" Class="ml-auto shrink-0">2h ago</Badge>
                            </div>
                            <div class="flex items-start gap-3">
                                <span class="mt-0.5 h-2 w-2 shrink-0 rounded-full bg-destructive"></span>
                                <div>
                                    <p class="text-sm font-medium">Security update</p>
                                    <p class="text-xs text-muted-foreground">A dependency requires an urgent patch.</p>
                                </div>
                                <Badge Variant="Badge.BadgeVariant.Destructive" Class="ml-auto shrink-0">Urgent</Badge>
                            </div>
                        </div>
                    </CardContent>
                    <CardFooter>
                        <Button Variant="Button.ButtonVariant.Outline" Class="w-full">Mark all as read</Button>
                    </CardFooter>
                </Card>
            </div>
            <pre class="code-example"><code>&lt;Card&gt;
    &lt;CardHeader&gt;
        &lt;CardTitle&gt;Notifications&lt;/CardTitle&gt;
        &lt;CardDescription&gt;You have 3 unread messages.&lt;/CardDescription&gt;
    &lt;/CardHeader&gt;
    &lt;CardContent&gt;
        &lt;div class="flex items-start gap-3"&gt;
            &lt;span class="h-2 w-2 rounded-full bg-primary"&gt;&lt;/span&gt;
            &lt;div&gt;
                &lt;p class="text-sm font-medium"&gt;New component released&lt;/p&gt;
                &lt;p class="text-xs text-muted-foreground"&gt;Dialog is now available.&lt;/p&gt;
            &lt;/div&gt;
            &lt;Badge Variant="Badge.BadgeVariant.Secondary"&gt;1h ago&lt;/Badge&gt;
        &lt;/div&gt;
    &lt;/CardContent&gt;
    &lt;CardFooter&gt;
        &lt;Button Variant="Button.ButtonVariant.Outline" Class="w-full"&gt;Mark all as read&lt;/Button&gt;
    &lt;/CardFooter&gt;
&lt;/Card&gt;</code></pre>
        </div>

        <!-- Feature Card with Custom Class -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Custom Styling</h3>
            <div class="grid gap-6 sm:grid-cols-2">
                <Card Class="border-primary/50">
                    <CardHeader>
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-primary">
                                <path d="m13 2 7 7-7 7"/><path d="m6 9 4 4-4 4"/>
                            </svg>
                            <CardTitle>Blazor Native</CardTitle>
                        </div>
                        <CardDescription>Pure C# components — no JavaScript wrappers.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="flex flex-wrap gap-2">
                            <Badge>WASM</Badge>
                            <Badge Variant="Badge.BadgeVariant.Outline">.NET 10</Badge>
                            <Badge Variant="Badge.BadgeVariant.Secondary">AOT Ready</Badge>
                        </div>
                    </CardContent>
                </Card>
                <Card Class="border-accent/50">
                    <CardHeader>
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-accent">
                                <path d="M12 3v18"/><path d="m8 7 4-4 4 4"/><path d="m8 17 4 4 4-4"/>
                            </svg>
                            <CardTitle>Fully Customizable</CardTitle>
                        </div>
                        <CardDescription>You own the code. Override anything.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="flex flex-wrap gap-2">
                            <Badge Variant="Badge.BadgeVariant.Outline">Tailwind v4</Badge>
                            <Badge Variant="Badge.BadgeVariant.Outline">OKLCH Colors</Badge>
                            <Badge Variant="Badge.BadgeVariant.Outline">CSS Variables</Badge>
                        </div>
                    </CardContent>
                </Card>
            </div>
            <pre class="code-example"><code>&lt;Card Class="border-primary/50"&gt;
    &lt;CardHeader&gt;
        &lt;div class="flex items-center gap-2"&gt;
            &lt;svg class="h-5 w-5 text-primary"&gt;...&lt;/svg&gt;
            &lt;CardTitle&gt;Blazor Native&lt;/CardTitle&gt;
        &lt;/div&gt;
        &lt;CardDescription&gt;Pure C# components — no JavaScript wrappers.&lt;/CardDescription&gt;
    &lt;/CardHeader&gt;
    &lt;CardContent&gt;
        &lt;Badge&gt;WASM&lt;/Badge&gt;
        &lt;Badge Variant="Badge.BadgeVariant.Outline"&gt;.NET 10&lt;/Badge&gt;
    &lt;/CardContent&gt;
&lt;/Card&gt;</code></pre>
        </div>
    </section>

</div>
