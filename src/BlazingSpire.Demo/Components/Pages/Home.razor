        </div>
    </section>

    <!-- ──────────────────────────────────────────────── -->
    <!-- SLIDER -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Slider</h2>
            <p class="text-sm text-muted-foreground mt-1">A range input with custom styling. Supports min, max, step, and disabled states.</p>
        </div>

        <!-- Default -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Default</h3>
            <div class="w-80">
                <Slider @bind-Value="_sliderValue" />
            </div>
            <p class="text-sm text-muted-foreground">Value: @_sliderValue</p>
            <pre class="language-xml"><code class="language-xml">&lt;Slider @@bind-Value="sliderValue" /&gt;</code></pre>
        </div>

        <!-- Custom range -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Custom Range</h3>
            <div class="w-80">
                <Slider @bind-Value="_sliderLargeValue" Min="0" Max="1000" Step="10" />
            </div>
            <p class="text-sm text-muted-foreground">Value: @_sliderLargeValue</p>
            <pre class="language-xml"><code class="language-xml">&lt;Slider @@bind-Value="sliderValue" Min="0" Max="1000" Step="10" /&gt;</code></pre>
        </div>

        <!-- Disabled -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Disabled</h3>
            <div class="w-80">
                <Slider Value="40" Disabled="true" />
            </div>
            <pre class="language-xml"><code class="language-xml">&lt;Slider Value="40" Disabled="true" /&gt;</code></pre>
        </div>
    </section>

    <!-- ──────────────────────────────────────────────── -->
    <!-- SCROLLAREA -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">ScrollArea</h2>
            <p class="text-sm text-muted-foreground mt-1">A styled scrollable container with hidden overflow and a full-height inner scroll viewport.</p>
        </div>

        <!-- Basic usage -->
        <div class="space-y-3">
            <h3 class="text-lg font-medium">Basic</h3>
            <ScrollArea Class="h-72 w-48 rounded-md border">
                <div class="p-4">
                    <h4 class="mb-4 text-sm font-medium leading-none">Tags</h4>
                    @foreach (var tag in _scrollTags)
                    {
                        <div class="text-sm py-1 border-b border-border last:border-0">@tag</div>
                    }
                </div>
            </ScrollArea>
            <pre class="language-xml"><code class="language-xml">&lt;ScrollArea Class="h-72 w-48 rounded-md border"&gt;
    &lt;div class="p-4"&gt;
        &lt;h4 class="mb-4 text-sm font-medium leading-none"&gt;Tags&lt;/h4&gt;
        @@foreach (var tag in tags)
        {
            &lt;div class="text-sm py-1 border-b border-border last:border-0"&gt;@@tag&lt;/div&gt;
        }
    &lt;/div&gt;
&lt;/ScrollArea&gt;</code></pre>
        </div>
    </section>

    <!-- ──────────────────────────────────────────────── -->
    <!-- PAGINATION -->
    <!-- ──────────────────────────────────────────────── -->
    <section class="space-y-6">
        <div>
            <h2 class="text-2xl font-semibold tracking-tight">Pagination</h2>
            <p class="text-sm text-muted-foreground mt-1">Navigation control for paginated content with previous, next, numbered pages, and ellipsis.</p>
        </div>

        <div class="space-y-3">
            <h3 class="text-lg font-medium">Default</h3>
            <Pagination>
                <PaginationContent>
                    <PaginationItem>
                        <PaginationPrevious Href="#" />
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationLink Href="#">1</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationLink Href="#" IsActive="true">2</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationLink Href="#">3</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationEllipsis />
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationNext Href="#" />
                    </PaginationItem>
                </PaginationContent>
            </Pagination>
            <pre class="language-xml"><code class="language-xml">&lt;Pagination&gt;
    &lt;PaginationContent&gt;
        &lt;PaginationItem&gt;
            &lt;PaginationPrevious Href="#" /&gt;
        &lt;/PaginationItem&gt;
        &lt;PaginationItem&gt;
            &lt;PaginationLink Href="#"&gt;1&lt;/PaginationLink&gt;
        &lt;/PaginationItem&gt;
        &lt;PaginationItem&gt;
            &lt;PaginationLink Href="#" IsActive="true"&gt;2&lt;/PaginationLink&gt;
        &lt;/PaginationItem&gt;
        &lt;PaginationItem&gt;
            &lt;PaginationLink Href="#"&gt;3&lt;/PaginationLink&gt;
