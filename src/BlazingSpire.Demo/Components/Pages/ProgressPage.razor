@page "/components/progress"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Progress - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Progress</h1>
        <p class="text-lg text-muted-foreground">Displays an indicator showing the completion progress of a task.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Progress Value="60" Class="w-[300px]" />
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Progress Value=&quot;60&quot; /&gt;</code></pre>
    </div>

    @* ── Values ─────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Values</h2>
        <div class="flex flex-col gap-4 rounded-xl border bg-muted/30 p-8">
            <div class="space-y-1.5">
                <span class="text-xs text-muted-foreground">0%</span>
                <Progress Value="0" />
            </div>
            <div class="space-y-1.5">
                <span class="text-xs text-muted-foreground">25%</span>
                <Progress Value="25" />
            </div>
            <div class="space-y-1.5">
                <span class="text-xs text-muted-foreground">50%</span>
                <Progress Value="50" />
            </div>
            <div class="space-y-1.5">
                <span class="text-xs text-muted-foreground">75%</span>
                <Progress Value="75" />
            </div>
            <div class="space-y-1.5">
                <span class="text-xs text-muted-foreground">100%</span>
                <Progress Value="100" />
            </div>
        </div>
    </div>

</div>
