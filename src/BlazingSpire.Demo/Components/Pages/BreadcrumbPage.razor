@page "/components/breadcrumb"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Breadcrumb - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Breadcrumb</h1>
        <p class="text-lg text-muted-foreground">Shows the current location within a navigational hierarchy.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Breadcrumb>
                <BreadcrumbList>
                    <BreadcrumbItem>
                        <BreadcrumbLink Href="/">Home</BreadcrumbLink>
                    </BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem>
                        <BreadcrumbLink Href="/components/button">Components</BreadcrumbLink>
                    </BreadcrumbItem>
                    <BreadcrumbSeparator />
                    <BreadcrumbItem>
                        <BlazingSpire.Demo.Components.UI.BreadcrumbPage>Breadcrumb</BlazingSpire.Demo.Components.UI.BreadcrumbPage>
                    </BreadcrumbItem>
                </BreadcrumbList>
            </Breadcrumb>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Breadcrumb&gt;
    &lt;BreadcrumbList&gt;
        &lt;BreadcrumbItem&gt;
            &lt;BreadcrumbLink Href=&quot;/&quot;&gt;Home&lt;/BreadcrumbLink&gt;
        &lt;/BreadcrumbItem&gt;
        &lt;BreadcrumbSeparator /&gt;
        &lt;BreadcrumbItem&gt;
            &lt;BreadcrumbLink Href=&quot;/components&quot;&gt;Components&lt;/BreadcrumbLink&gt;
        &lt;/BreadcrumbItem&gt;
        &lt;BreadcrumbSeparator /&gt;
        &lt;BreadcrumbItem&gt;
            &lt;BreadcrumbPage&gt;Breadcrumb&lt;/BreadcrumbPage&gt;
        &lt;/BreadcrumbItem&gt;
    &lt;/BreadcrumbList&gt;
&lt;/Breadcrumb&gt;</code></pre>
    </div>

</div>
