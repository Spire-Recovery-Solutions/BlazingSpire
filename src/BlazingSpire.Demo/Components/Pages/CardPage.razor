@page "/components/card"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Card - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Card</h1>
        <p class="text-lg text-muted-foreground">A container for grouping related content and actions.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Card Class="w-[350px]">
                <CardHeader>
                    <CardTitle>Card Title</CardTitle>
                    <CardDescription>Card description goes here.</CardDescription>
                </CardHeader>
                <CardContent>
                    <p class="text-sm text-muted-foreground">Card content area for your main information.</p>
                </CardContent>
                <CardFooter Class="flex justify-between">
                    <Button Variant="ButtonVariant.Outline">Cancel</Button>
                    <Button>Save</Button>
                </CardFooter>
            </Card>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Card&gt;
    &lt;CardHeader&gt;
        &lt;CardTitle&gt;Card Title&lt;/CardTitle&gt;
        &lt;CardDescription&gt;Card description goes here.&lt;/CardDescription&gt;
    &lt;/CardHeader&gt;
    &lt;CardContent&gt;
        &lt;p&gt;Card content area.&lt;/p&gt;
    &lt;/CardContent&gt;
    &lt;CardFooter&gt;
        &lt;Button Variant=&quot;ButtonVariant.Outline&quot;&gt;Cancel&lt;/Button&gt;
        &lt;Button&gt;Save&lt;/Button&gt;
    &lt;/CardFooter&gt;
&lt;/Card&gt;</code></pre>
    </div>

</div>
