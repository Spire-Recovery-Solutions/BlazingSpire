@page "/components/skeleton"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Skeleton - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Skeleton</h1>
        <p class="text-lg text-muted-foreground">A placeholder animation shown while content is loading.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="flex items-center gap-4">
                <Skeleton Class="h-12 w-12 rounded-full" />
                <div class="space-y-2">
                    <Skeleton Class="h-4 w-[250px]" />
                    <Skeleton Class="h-4 w-[200px]" />
                </div>
            </div>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;div class=&quot;flex items-center gap-4&quot;&gt;
    &lt;Skeleton Class=&quot;h-12 w-12 rounded-full&quot; /&gt;
    &lt;div class=&quot;space-y-2&quot;&gt;
        &lt;Skeleton Class=&quot;h-4 w-[250px]&quot; /&gt;
        &lt;Skeleton Class=&quot;h-4 w-[200px]&quot; /&gt;
    &lt;/div&gt;
&lt;/div&gt;</code></pre>
    </div>

    @* ── Card Skeleton ───────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Card Skeleton</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-[300px] space-y-3">
                <Skeleton Class="h-[150px] w-full rounded-xl" />
                <div class="space-y-2">
                    <Skeleton Class="h-4 w-full" />
                    <Skeleton Class="h-4 w-3/4" />
                </div>
            </div>
        </div>
    </div>

</div>
