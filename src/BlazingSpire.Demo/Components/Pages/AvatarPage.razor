@page "/components/avatar"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Avatar - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Avatar</h1>
        <p class="text-lg text-muted-foreground">An image element with a fallback for representing a user.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Avatar>
                <AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn" />
                <AvatarFallback>CN</AvatarFallback>
            </Avatar>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Avatar&gt;
    &lt;AvatarImage Src=&quot;https://github.com/shadcn.png&quot; Alt=&quot;shadcn&quot; /&gt;
    &lt;AvatarFallback&gt;CN&lt;/AvatarFallback&gt;
&lt;/Avatar&gt;</code></pre>
    </div>

    @* ── Fallback ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">With Fallback</h2>
        <div class="flex flex-wrap items-center gap-4 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">With Image</span>
                <Avatar>
                    <AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn" />
                    <AvatarFallback>CN</AvatarFallback>
                </Avatar>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Fallback Only</span>
                <Avatar>
                    <AvatarFallback>AB</AvatarFallback>
                </Avatar>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Broken Image</span>
                <Avatar>
                    <AvatarImage Src="/nonexistent.png" Alt="broken" />
                    <AvatarFallback>JD</AvatarFallback>
                </Avatar>
            </div>
        </div>
    </div>

</div>
