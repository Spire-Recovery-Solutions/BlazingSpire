@page "/components/sheet"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Sheet - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Sheet</h1>
        <p class="text-lg text-muted-foreground">A panel that slides in from the edge of the screen.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Sheet @bind-IsOpen="_isOpen">
                <SheetTrigger>
                    <Button Variant="ButtonVariant.Outline">Open Sheet</Button>
                </SheetTrigger>
                <SheetContent>
                    <SheetHeader>
                        <SheetTitle>Edit Profile</SheetTitle>
                        <SheetDescription>Make changes to your profile here. Click save when you're done.</SheetDescription>
                    </SheetHeader>
                    <div class="grid gap-4 py-4">
                        <div class="grid grid-cols-4 items-center gap-4">
                            <Label Class="text-right">Name</Label>
                            <Input Class="col-span-3" Placeholder="Enter your name" />
                        </div>
                    </div>
                    <SheetFooter>
                        <SheetClose>
                            <Button Variant="ButtonVariant.Outline">Cancel</Button>
                        </SheetClose>
                        <Button>Save changes</Button>
                    </SheetFooter>
                </SheetContent>
            </Sheet>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Sheet &#64;bind-IsOpen=&quot;_isOpen&quot;&gt;
    &lt;SheetTrigger&gt;
        &lt;Button Variant=&quot;ButtonVariant.Outline&quot;&gt;Open Sheet&lt;/Button&gt;
    &lt;/SheetTrigger&gt;
    &lt;SheetContent&gt;
        &lt;SheetHeader&gt;
            &lt;SheetTitle&gt;Edit Profile&lt;/SheetTitle&gt;
            &lt;SheetDescription&gt;Make changes to your profile here.&lt;/SheetDescription&gt;
        &lt;/SheetHeader&gt;
        &lt;SheetFooter&gt;
            &lt;SheetClose&gt;
                &lt;Button Variant=&quot;ButtonVariant.Outline&quot;&gt;Cancel&lt;/Button&gt;
            &lt;/SheetClose&gt;
            &lt;Button&gt;Save changes&lt;/Button&gt;
        &lt;/SheetFooter&gt;
    &lt;/SheetContent&gt;
&lt;/Sheet&gt;</code></pre>
    </div>

    @* ── Variants ───────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Variants</h2>
        <div class="flex flex-wrap items-center gap-4 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Top</span>
                <Sheet @bind-IsOpen="_sheetTopOpen">
                    <SheetTrigger>
                        <Button Variant="ButtonVariant.Outline">Top</Button>
                    </SheetTrigger>
                    <SheetContent Side="SheetSide.Top">
                        <SheetHeader>
                            <SheetTitle>Top Sheet</SheetTitle>
                            <SheetDescription>This sheet slides in from the top.</SheetDescription>
                        </SheetHeader>
                    </SheetContent>
                </Sheet>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Right</span>
                <Sheet @bind-IsOpen="_sheetRightOpen">
                    <SheetTrigger>
                        <Button Variant="ButtonVariant.Outline">Right</Button>
                    </SheetTrigger>
                    <SheetContent Side="SheetSide.Right">
                        <SheetHeader>
                            <SheetTitle>Right Sheet</SheetTitle>
                            <SheetDescription>This sheet slides in from the right.</SheetDescription>
                        </SheetHeader>
                    </SheetContent>
                </Sheet>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Bottom</span>
                <Sheet @bind-IsOpen="_sheetBottomOpen">
                    <SheetTrigger>
                        <Button Variant="ButtonVariant.Outline">Bottom</Button>
                    </SheetTrigger>
                    <SheetContent Side="SheetSide.Bottom">
                        <SheetHeader>
                            <SheetTitle>Bottom Sheet</SheetTitle>
                            <SheetDescription>This sheet slides in from the bottom.</SheetDescription>
                        </SheetHeader>
                    </SheetContent>
                </Sheet>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Left</span>
                <Sheet @bind-IsOpen="_sheetLeftOpen">
                    <SheetTrigger>
                        <Button Variant="ButtonVariant.Outline">Left</Button>
                    </SheetTrigger>
                    <SheetContent Side="SheetSide.Left">
                        <SheetHeader>
                            <SheetTitle>Left Sheet</SheetTitle>
                            <SheetDescription>This sheet slides in from the left.</SheetDescription>
                        </SheetHeader>
                    </SheetContent>
                </Sheet>
            </div>
        </div>
    </div>

</div>

@code {
    private bool _isOpen;
    private bool _sheetTopOpen;
    private bool _sheetRightOpen;
    private bool _sheetBottomOpen;
    private bool _sheetLeftOpen;
}
