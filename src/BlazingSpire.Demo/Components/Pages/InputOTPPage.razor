@page "/components/input-otp"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Input OTP - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Input OTP</h1>
        <p class="text-lg text-muted-foreground">An accessible one-time password input with individual digit slots.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex flex-col items-center justify-center gap-3 rounded-xl border bg-muted/30 p-8">
            <InputOTP @bind-Value="_otp" MaxLength="6">
                <InputOTPGroup>
                    <InputOTPSlot Index="0" />
                    <InputOTPSlot Index="1" />
                    <InputOTPSlot Index="2" />
                </InputOTPGroup>
                <InputOTPSeparator />
                <InputOTPGroup>
                    <InputOTPSlot Index="3" />
                    <InputOTPSlot Index="4" />
                    <InputOTPSlot Index="5" />
                </InputOTPGroup>
            </InputOTP>
            <p class="text-sm text-muted-foreground">Value: @(_otp.Length > 0 ? _otp : "—")</p>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;InputOTP &#64;bind-Value=&quot;_otp&quot; MaxLength=&quot;6&quot;&gt;
    &lt;InputOTPGroup&gt;
        &lt;InputOTPSlot Index=&quot;0&quot; /&gt;
        &lt;InputOTPSlot Index=&quot;1&quot; /&gt;
        &lt;InputOTPSlot Index=&quot;2&quot; /&gt;
    &lt;/InputOTPGroup&gt;
    &lt;InputOTPSeparator /&gt;
    &lt;InputOTPGroup&gt;
        &lt;InputOTPSlot Index=&quot;3&quot; /&gt;
        &lt;InputOTPSlot Index=&quot;4&quot; /&gt;
        &lt;InputOTPSlot Index=&quot;5&quot; /&gt;
    &lt;/InputOTPGroup&gt;
&lt;/InputOTP&gt;

@@code {
    private string _otp = &quot;&quot;;
}</code></pre>
    </div>

    @* ── Examples ───────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Examples</h2>
        <div class="grid gap-6 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">4 digits</span>
                <InputOTP MaxLength="4">
                    <InputOTPGroup>
                        <InputOTPSlot Index="0" />
                        <InputOTPSlot Index="1" />
                        <InputOTPSlot Index="2" />
                        <InputOTPSlot Index="3" />
                    </InputOTPGroup>
                </InputOTP>
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Disabled</span>
                <InputOTP MaxLength="6" Disabled="true">
                    <InputOTPGroup>
                        <InputOTPSlot Index="0" />
                        <InputOTPSlot Index="1" />
                        <InputOTPSlot Index="2" />
                    </InputOTPGroup>
                    <InputOTPSeparator />
                    <InputOTPGroup>
                        <InputOTPSlot Index="3" />
                        <InputOTPSlot Index="4" />
                        <InputOTPSlot Index="5" />
                    </InputOTPGroup>
                </InputOTP>
            </div>
        </div>
    </div>

</div>

@code {
    private string _otp = "";
}
