@page "/components/slider"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Slider - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Slider</h1>
        <p class="text-lg text-muted-foreground">A range input for selecting a numeric value.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-full max-w-sm space-y-2">
                <Slider @bind-Value="_value" />
                <p class="text-center text-sm text-muted-foreground">Value: @_value</p>
            </div>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Slider &#64;bind-Value=&quot;_value&quot; /&gt;

@@code {
    private double _value = 50;
}</code></pre>
    </div>

    @* ── Examples ───────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Examples</h2>
        <div class="grid gap-6 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Default (0–100)</span>
                <Slider Value="30" />
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Step 10</span>
                <Slider Value="50" Step="10" />
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Custom range (0–200)</span>
                <Slider Value="75" Min="0" Max="200" />
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Disabled</span>
                <Slider Value="40" Disabled="true" />
            </div>
        </div>
    </div>

</div>

@code {
    private double _value = 50;
}
