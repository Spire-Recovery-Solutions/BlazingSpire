    </div>

</div>

@code {
    private record Invoice(string Id, string Status, string Method, decimal Amount);

    private List<Invoice> _invoices =
    [
        new("INV-001", "Paid", "Credit Card", 316.00m),
        new("INV-002", "Pending", "PayPal", 242.00m),
        new("INV-003", "Unpaid", "Bank Transfer", 837.00m),
        new("INV-004", "Paid", "Credit Card", 874.00m),
        new("INV-005", "Paid", "PayPal", 721.00m),
    ];

    private string? _sortColumn;
    private bool _sortAscending = true;

    private void HandleSort(string column)
    {
        if (_sortColumn == column)
            _sortAscending = !_sortAscending;
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }

        _invoices = (_sortColumn, _sortAscending) switch
        {
            ("Id", true) => [.. _invoices.OrderBy(i => i.Id)],
            ("Id", false) => [.. _invoices.OrderByDescending(i => i.Id)],
            ("Status", true) => [.. _invoices.OrderBy(i => i.Status)],
            ("Status", false) => [.. _invoices.OrderByDescending(i => i.Status)],
            ("Method", true) => [.. _invoices.OrderBy(i => i.Method)],
            ("Method", false) => [.. _invoices.OrderByDescending(i => i.Method)],
            ("Amount", true) => [.. _invoices.OrderBy(i => i.Amount)],
            ("Amount", false) => [.. _invoices.OrderByDescending(i => i.Amount)],
            _ => _invoices
        };
    }
}
