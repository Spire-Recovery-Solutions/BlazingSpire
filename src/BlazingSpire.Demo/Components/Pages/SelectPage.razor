@page "/components/select"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Select - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Select</h1>
        <p class="text-lg text-muted-foreground">Displays a list of options for the user to pick from.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex flex-col items-center gap-4 rounded-xl border bg-muted/30 p-8">
            <div class="w-64">
                <Select @bind-Value="_selected" Placeholder="Select a fruit">
                    <SelectTrigger>
                        <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectItem ItemValue="apple">Apple</SelectItem>
                        <SelectItem ItemValue="banana">Banana</SelectItem>
                        <SelectItem ItemValue="cherry">Cherry</SelectItem>
                        <SelectItem ItemValue="date">Date</SelectItem>
                        <SelectItem ItemValue="elderberry">Elderberry</SelectItem>
                    </SelectContent>
                </Select>
            </div>
            @if (!string.IsNullOrEmpty(_selected))
            {
                <p class="text-sm text-muted-foreground">Selected: <span class="font-medium text-foreground">@_selected</span></p>
            }
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Select &#64;bind-Value=&quot;_selected&quot; Placeholder=&quot;Select a fruit&quot;&gt;
    &lt;SelectTrigger&gt;
        &lt;SelectValue /&gt;
    &lt;/SelectTrigger&gt;
    &lt;SelectContent&gt;
        &lt;SelectItem ItemValue=&quot;apple&quot;&gt;Apple&lt;/SelectItem&gt;
        &lt;SelectItem ItemValue=&quot;banana&quot;&gt;Banana&lt;/SelectItem&gt;
        &lt;SelectItem ItemValue=&quot;cherry&quot;&gt;Cherry&lt;/SelectItem&gt;
        &lt;SelectItem ItemValue=&quot;date&quot;&gt;Date&lt;/SelectItem&gt;
        &lt;SelectItem ItemValue=&quot;elderberry&quot;&gt;Elderberry&lt;/SelectItem&gt;
    &lt;/SelectContent&gt;
&lt;/Select&gt;

@@code {
    private string? _selected;
}</code></pre>
    </div>

    @* ── With Groups ────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">With Groups</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-64">
                <Select Placeholder="Select a timezone">
                    <SelectTrigger>
                        <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>North America</SelectLabel>
                            <SelectItem ItemValue="est">Eastern (UTC-5)</SelectItem>
                            <SelectItem ItemValue="cst">Central (UTC-6)</SelectItem>
                            <SelectItem ItemValue="pst">Pacific (UTC-8)</SelectItem>
                        </SelectGroup>
                        <SelectSeparator />
                        <SelectGroup>
                            <SelectLabel>Europe</SelectLabel>
                            <SelectItem ItemValue="gmt">GMT (UTC+0)</SelectItem>
                            <SelectItem ItemValue="cet">Central European (UTC+1)</SelectItem>
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </div>
        </div>
    </div>

</div>

@code {
    private string? _selected;
}
