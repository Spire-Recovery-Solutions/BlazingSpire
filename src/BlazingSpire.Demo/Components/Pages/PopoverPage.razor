@page "/components/popover"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Popover - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Popover</h1>
        <p class="text-lg text-muted-foreground">A floating panel anchored to a trigger element.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Popover>
                <PopoverTrigger>
                    <Button Variant="ButtonVariant.Outline">Open Popover</Button>
                </PopoverTrigger>
                <PopoverContent>
                    <div class="space-y-2">
                        <h4 class="font-medium leading-none">Dimensions</h4>
                        <p class="text-sm text-muted-foreground">Set the dimensions for the layer.</p>
                    </div>
                    <div class="grid gap-2 pt-2">
                        <div class="grid grid-cols-3 items-center gap-4">
                            <Label>Width</Label>
                            <Input Class="col-span-2 h-8" Value="100%" />
                        </div>
                        <div class="grid grid-cols-3 items-center gap-4">
                            <Label>Max. width</Label>
                            <Input Class="col-span-2 h-8" Value="300px" />
                        </div>
                    </div>
                </PopoverContent>
            </Popover>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Popover&gt;
    &lt;PopoverTrigger&gt;
        &lt;Button Variant=&quot;ButtonVariant.Outline&quot;&gt;Open Popover&lt;/Button&gt;
    &lt;/PopoverTrigger&gt;
    &lt;PopoverContent&gt;
        &lt;div class=&quot;space-y-2&quot;&gt;
            &lt;h4 class=&quot;font-medium leading-none&quot;&gt;Dimensions&lt;/h4&gt;
            &lt;p class=&quot;text-sm text-muted-foreground&quot;&gt;Set the dimensions for the layer.&lt;/p&gt;
        &lt;/div&gt;
    &lt;/PopoverContent&gt;
&lt;/Popover&gt;</code></pre>
    </div>

</div>
