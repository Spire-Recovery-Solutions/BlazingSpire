@page "/components/textarea"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Textarea - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Textarea</h1>
        <p class="text-lg text-muted-foreground">A multi-line text input for longer content.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Textarea class="max-w-sm w-full" Placeholder="Write a message..." />
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Textarea Placeholder=&quot;Write a message...&quot; /&gt;</code></pre>
    </div>

    @* ── Examples ───────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Examples</h2>
        <div class="grid gap-4 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Default</span>
                <Textarea class="max-w-sm" Placeholder="Type your message here." />
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Disabled</span>
                <Textarea class="max-w-sm" Placeholder="Disabled textarea" Disabled="true" />
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">With content</span>
                <Textarea class="max-w-sm">This textarea has some initial content.</Textarea>
            </div>
        </div>
    </div>

</div>
