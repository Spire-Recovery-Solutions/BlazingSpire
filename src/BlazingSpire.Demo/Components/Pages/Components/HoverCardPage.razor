@page "/components/hover-card"
@using BlazingSpire.Demo.Components.UI

<PageTitle>HoverCard - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Hover Card</h1>
        <p class="text-lg text-muted-foreground mt-2">A floating panel revealed on hover. Richer than a tooltip — supports interactive content like links and stats.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">User Profile</h2>
        <div class="rounded-lg border bg-card p-6 min-h-[180px]">
            <HoverCard>
                <HoverCardTrigger href="https://github.com/adamreed90" class="text-sm font-medium underline underline-offset-4 hover:text-primary transition-colors cursor-pointer">
                    @@adamreed90
                </HoverCardTrigger>
                <HoverCardContent>
                    <div class="flex gap-3">
                        <div class="h-10 w-10 rounded-full bg-muted flex items-center justify-center text-sm font-semibold shrink-0">AR</div>
                        <div class="space-y-1">
                            <h4 class="text-sm font-semibold">Adam Reed</h4>
                            <p class="text-xs text-muted-foreground">Building BlazingSpire — a Blazor component framework inspired by shadcn/ui.</p>
                            <div class="flex items-center gap-3 pt-1 text-xs text-muted-foreground">
                                <span><strong class="text-foreground">12</strong> Following</span>
                                <span><strong class="text-foreground">48</strong> Followers</span>
                            </div>
                        </div>
                    </div>
                </HoverCardContent>
            </HoverCard>
        </div>
