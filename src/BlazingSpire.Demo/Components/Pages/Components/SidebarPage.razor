@page "/components/sidebar"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Sidebar - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Sidebar</h1>
        <p class="text-lg text-muted-foreground mt-2">A collapsible navigation sidebar with header, content, footer, and a toggle trigger.</p>
    </div>

    @* ── Collapsible ─────────────────────── *@
    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Collapsible sidebar</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="h-64 overflow-hidden rounded-lg border">
                <Sidebar @bind-IsCollapsed="_sidebarCollapsed">
                    <SidebarHeader>
                        <SidebarTrigger />
                        @if (!_sidebarCollapsed)
                        {
                            <span class="ml-2 text-sm font-semibold">Navigation</span>
                        }
                    </SidebarHeader>
                    <SidebarContent>
                        <nav class="space-y-1 px-2">
                            <a href="javascript:void(0)" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0">
                                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                    <polyline points="9 22 9 12 15 12 15 22"/>
                                </svg>
                                @if (!_sidebarCollapsed) { <span>Home</span> }
                            </a>
                            <a href="javascript:void(0)" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0">
                                    <circle cx="11" cy="11" r="8"/>
                                    <path d="m21 21-4.3-4.3"/>
                                </svg>
                                @if (!_sidebarCollapsed) { <span>Search</span> }
                            </a>
                            <a href="javascript:void(0)" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0">
                                    <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                                @if (!_sidebarCollapsed) { <span>Settings</span> }
                            </a>
                        </nav>
                    </SidebarContent>
                    <SidebarFooter>
                        @if (!_sidebarCollapsed)
                        {
                            <p class="text-xs text-muted-foreground">v1.0.0</p>
                        }
                    </SidebarFooter>
                </Sidebar>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Sidebar &#64;bind-IsCollapsed="_isCollapsed"&gt;
    &lt;SidebarHeader&gt;
        &lt;SidebarTrigger /&gt;
        &#64;if (!_isCollapsed) &#123; &lt;span&gt;Navigation&lt;/span&gt; &#125;
    &lt;/SidebarHeader&gt;
    &lt;SidebarContent&gt;
        &lt;nav&gt;
            &lt;a href="javascript:void(0)"&gt;Home&lt;/a&gt;
            &lt;a href="javascript:void(0)"&gt;Search&lt;/a&gt;
        &lt;/nav&gt;
    &lt;/SidebarContent&gt;
    &lt;SidebarFooter&gt;
        &lt;p&gt;v1.0.0&lt;/p&gt;
    &lt;/SidebarFooter&gt;
&lt;/Sidebar&gt;

&#64;code &#123;
    private bool _isCollapsed;
&#125;</code></pre>
    </section>
</div>

@code {
    private bool _sidebarCollapsed;
}
