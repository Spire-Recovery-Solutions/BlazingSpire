@page "/components/form-field"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Form Field - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Form Field</h1>
        <p class="text-lg text-muted-foreground mt-2">Composition layer that wires ARIA attributes across label, control, description, and error message.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Basic</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm">
                <FormField Name="username-basic">
                    <FormFieldLabel>Username</FormFieldLabel>
                    <Input id="username-basic-form-item" Placeholder="Enter your username" />
                    <FormFieldDescription>This is your public display name.</FormFieldDescription>
                </FormField>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml"><span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>FormField</span> <span class="token attr-name">Name</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>username<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>FormFieldLabel</span><span class="token punctuation">></span></span>Username<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>FormFieldLabel</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>Input</span> <span class="token attr-name">id</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>username-form-item<span class="token punctuation">"</span></span> <span class="token attr-name">Placeholder</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Enter your username<span class="token punctuation">"</span></span> <span class="token punctuation">/></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>FormFieldDescription</span><span class="token punctuation">></span></span>This is your public display name.<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>FormFieldDescription</span><span class="token punctuation">></span></span>
<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>FormField</span><span class="token punctuation">></span></span></code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">With Error</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm">
                <FormField Name="username-error" ErrorMessage="Username is required.">
                    <FormFieldLabel>Username</FormFieldLabel>
                    <Input id="username-error-form-item" Placeholder="Enter your username" />
                    <FormFieldDescription>This is your public display name.</FormFieldDescription>
                    <FormFieldError />
                </FormField>
            </div>
        </div>
