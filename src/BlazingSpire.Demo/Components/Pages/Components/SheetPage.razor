@page "/components/sheet"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Sheet - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Sheet</h1>
        <p class="text-lg text-muted-foreground mt-2">A slide-in panel from any edge of the screen. Supports focus trap, scroll lock, and click-outside/Escape dismissal.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Edit Profile</h2>
        <div class="rounded-lg border bg-card p-6">
            <Sheet>
                <SheetTrigger>
                    <Button Variant="ButtonVariant.Outline">Open Sheet</Button>
                </SheetTrigger>
                <SheetContent>
                    <SheetClose />
                    <SheetHeader>
                        <SheetTitle>Edit profile</SheetTitle>
                        <SheetDescription>Make changes to your profile here. Click save when you&#39;re done.</SheetDescription>
                    </SheetHeader>
                    <div class="grid gap-4 py-4">
                        <div class="grid grid-cols-4 items-center gap-4">
                            <Label For="sheet-name" Class="text-right">Name</Label>
                            <Input id="sheet-name" Value="Adam Reed" Class="col-span-3" />
                        </div>
                        <div class="grid grid-cols-4 items-center gap-4">
                            <Label For="sheet-username" Class="text-right">Username</Label>
                            <Input id="sheet-username" Value="@("@adamreed")" Class="col-span-3" />
                        </div>
                    </div>
                    <SheetFooter>
                        <Button>Save changes</Button>
                    </SheetFooter>
                </SheetContent>
            </Sheet>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Sheet&gt;
    &lt;SheetTrigger&gt;
        &lt;Button Variant="ButtonVariant.Outline"&gt;Open Sheet&lt;/Button&gt;
    &lt;/SheetTrigger&gt;
    &lt;SheetContent&gt;
        &lt;SheetClose /&gt;
        &lt;SheetHeader&gt;
            &lt;SheetTitle&gt;Edit profile&lt;/SheetTitle&gt;
            &lt;SheetDescription&gt;Make changes to your profile here.&lt;/SheetDescription&gt;
        &lt;/SheetHeader&gt;
        &lt;div class="grid gap-4 py-4"&gt;
            &lt;div class="grid grid-cols-4 items-center gap-4"&gt;
                &lt;Label For="name" Class="text-right"&gt;Name&lt;/Label&gt;
                &lt;Input id="name" Value="Adam Reed" Class="col-span-3" /&gt;
            &lt;/div&gt;
        &lt;/div&gt;
        &lt;SheetFooter&gt;
            &lt;Button&gt;Save changes&lt;/Button&gt;
        &lt;/SheetFooter&gt;
    &lt;/SheetContent&gt;
&lt;/Sheet&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Sides</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="flex flex-wrap gap-3">
                <Sheet Side="SheetSide.Left">
                    <SheetTrigger>
                        <Button Variant="ButtonVariant.Outline">Left</Button>
                    </SheetTrigger>
                    <SheetContent>
                        <SheetClose />
                        <SheetHeader>
                            <SheetTitle>Left Sheet</SheetTitle>
                            <SheetDescription>Slides in from the left.</SheetDescription>
                        </SheetHeader>
                    </SheetContent>
                </Sheet>
                <Sheet Side="SheetSide.Top">
                    <SheetTrigger>
                        <Button Variant="ButtonVariant.Outline">Top</Button>
                    </SheetTrigger>
                    <SheetContent>
                        <SheetClose />
                        <SheetHeader>
                            <SheetTitle>Top Sheet</SheetTitle>
                            <SheetDescription>Slides in from the top.</SheetDescription>
                        </SheetHeader>
                    </SheetContent>
                </Sheet>
                <Sheet Side="SheetSide.Bottom">
                    <SheetTrigger>
                        <Button Variant="ButtonVariant.Outline">Bottom</Button>
                    </SheetTrigger>
                    <SheetContent>
                        <SheetClose />
                        <SheetHeader>
                            <SheetTitle>Bottom Sheet</SheetTitle>
                            <SheetDescription>Slides in from the bottom.</SheetDescription>
                        </SheetHeader>
                    </SheetContent>
                </Sheet>
                <Sheet Side="SheetSide.Right">
                    <SheetTrigger>
                        <Button Variant="ButtonVariant.Outline">Right</Button>
                    </SheetTrigger>
                    <SheetContent>
                        <SheetClose />
                        <SheetHeader>
                            <SheetTitle>Right Sheet</SheetTitle>
                            <SheetDescription>Slides in from the right.</SheetDescription>
                        </SheetHeader>
                    </SheetContent>
                </Sheet>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Sheet Side="SheetSide.Left"&gt; ... &lt;/Sheet&gt;
&lt;Sheet Side="SheetSide.Top"&gt; ... &lt;/Sheet&gt;
&lt;Sheet Side="SheetSide.Bottom"&gt; ... &lt;/Sheet&gt;
&lt;Sheet Side="SheetSide.Right"&gt; ... &lt;/Sheet&gt;</code></pre>
    </section>
</div>
