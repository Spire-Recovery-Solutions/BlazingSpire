@page "/components/input"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Input - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Input</h1>
        <p class="text-lg text-muted-foreground mt-2">Displays a form input field with two-way binding, adornments, and size variants.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Default</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm">
                <Input Placeholder="Email" />
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Input Placeholder="Email" /&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Types</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm space-y-2">
                <Input Type="email" Placeholder="Email" />
                <Input Type="password" Placeholder="Password" />
                <Input Type="file" />
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Input Type="email" Placeholder="Email" /&gt;
&lt;Input Type="password" Placeholder="Password" /&gt;
&lt;Input Type="file" /&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">With Label</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm space-y-2">
                <Label For="email-demo">Email</Label>
                <Input Type="email" Placeholder="m@example.com" id="email-demo" />
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Label For="email"&gt;Email&lt;/Label&gt;
&lt;Input Type="email" Placeholder="m&#64;example.com" id="email" /&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Two-Way Binding</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm space-y-2">
                <Input Placeholder="Type something..." @bind-Value="_boundValue" Immediate="true" />
                <p class="text-sm text-muted-foreground">Value: @(_boundValue ?? "(empty)")</p>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Input Placeholder="Type something..."
       @@bind-Value="_value"
       Immediate="true" /&gt;
&lt;p&gt;Value: @@_value&lt;/p&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Sizes</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm space-y-2">
                <Input Size="InputSize.Sm" Placeholder="Small" />
                <Input Placeholder="Default" />
                <Input Size="InputSize.Lg" Placeholder="Large" />
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Input Size="InputSize.Sm" Placeholder="Small" /&gt;
&lt;Input Placeholder="Default" /&gt;
&lt;Input Size="InputSize.Lg" Placeholder="Large" /&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">With Adornments</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm space-y-2">
                <Input Placeholder="0.00">
                    <Prefix>$</Prefix>
                </Input>
                <Input Placeholder="Weight">
                    <Suffix>kg</Suffix>
                </Input>
                <Input Placeholder="Search..." Type="search">
                    <Prefix>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                        </svg>
                    </Prefix>
                </Input>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Input Placeholder="0.00"&gt;
    &lt;Prefix&gt;$&lt;/Prefix&gt;
&lt;/Input&gt;

&lt;Input Placeholder="Weight"&gt;
    &lt;Suffix&gt;kg&lt;/Suffix&gt;
&lt;/Input&gt;

&lt;Input Placeholder="Search..." Type="search"&gt;
    &lt;Prefix&gt;
        &lt;svg class="h-4 w-4"&gt;...&lt;/svg&gt;
    &lt;/Prefix&gt;
&lt;/Input&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Disabled</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm">
                <Input Placeholder="Disabled input" Disabled="true" />
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Input Placeholder="Disabled input" Disabled="true" /&gt;</code></pre>
    </section>
</div>

@code {
    private string? _boundValue;
}
