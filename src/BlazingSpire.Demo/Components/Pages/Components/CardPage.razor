@page "/components/card"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Card - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Card</h1>
        <p class="text-lg text-muted-foreground mt-2">Structured containers for grouping related content. Composable via CardHeader, CardContent, and CardFooter.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Basic</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                <Card>
                    <CardHeader>
                        <CardTitle>Create project</CardTitle>
                        <CardDescription>Deploy your new project in one-click.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm text-muted-foreground">
                            Pre-configured with .NET 10, Tailwind CSS v4, and optimized WASM delivery.
                        </p>
                    </CardContent>
                    <CardFooter>
                        <Button>Deploy</Button>
                    </CardFooter>
                </Card>

                <Card>
                    <CardHeader>
                        <CardTitle>Components</CardTitle>
                        <CardDescription>Browse the component library.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <div class="flex flex-wrap gap-2">
                            <Badge>Button</Badge>
                            <Badge Variant="BadgeVariant.Secondary">Card</Badge>
                            <Badge Variant="BadgeVariant.Outline">Badge</Badge>
                            <Badge Variant="BadgeVariant.Secondary">Dialog</Badge>
                        </div>
                    </CardContent>
                    <CardFooter>
                        <Button Variant="ButtonVariant.Outline">Browse</Button>
                    </CardFooter>
                </Card>

                <Card>
                    <CardHeader>
                        <CardTitle>Documentation</CardTitle>
                        <CardDescription>Learn how to use BlazingSpire.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <p class="text-sm text-muted-foreground">
                            Copy-paste components into your Blazor project. You own the code.
                        </p>
                    </CardContent>
                    <CardFooter>
                        <Button Variant="ButtonVariant.Ghost">Read docs</Button>
                    </CardFooter>
                </Card>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml"><span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>Card</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>CardHeader</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>CardTitle</span><span class="token punctuation">></span></span>Create project<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>CardTitle</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>CardDescription</span><span class="token punctuation">></span></span>Deploy your new project in one-click.<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>CardDescription</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>CardHeader</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>CardContent</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>p</span><span class="token punctuation">></span></span>Pre-configured with .NET 10 and Tailwind CSS v4.<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>p</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>CardContent</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>CardFooter</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>Button</span><span class="token punctuation">></span></span>Deploy<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>Button</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>CardFooter</span><span class="token punctuation">></span></span>
<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>Card</span><span class="token punctuation">></span></span></code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Stats</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                <Card>
                    <CardHeader>
                        <CardDescription>Total Downloads</CardDescription>
                        <CardTitle Class="text-3xl">2,350</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-xs text-muted-foreground">+180 from last month</p>
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <CardDescription>Active Users</CardDescription>
                        <CardTitle Class="text-3xl">573</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-xs text-muted-foreground">+24 from last week</p>
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <CardDescription>Components</CardDescription>
                        <CardTitle Class="text-3xl">47</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-xs text-muted-foreground">Full shadcn/ui catalog</p>
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <CardDescription>Lighthouse Score</CardDescription>
                        <CardTitle Class="text-3xl">100</CardTitle>
                    </CardHeader>
                    <CardContent>
                        <p class="text-xs text-muted-foreground">Performance / A11y / SEO / BP</p>
                    </CardContent>
                </Card>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml"><span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>Card</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>CardHeader</span><span class="token punctuation">></span></span>
