@page "/components/progress"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Progress - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Progress</h1>
        <p class="text-lg text-muted-foreground mt-2">Displays a progress bar indicating task completion.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Values</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm space-y-3">
                <Progress Value="25" />
                <Progress Value="50" />
                <Progress Value="75" />
                <Progress Value="100" />
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Progress Value="25" /&gt;
&lt;Progress Value="50" /&gt;
&lt;Progress Value="75" /&gt;
&lt;Progress Value="100" /&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">With Label</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="max-w-sm space-y-2">
                <div class="flex justify-between text-sm">
                    <span>Uploading...</span>
                    <span class="text-muted-foreground">66%</span>
                </div>
                <Progress Value="66" aria-label="File upload progress" />
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;div class="flex justify-between text-sm"&gt;
    &lt;span&gt;Uploading...&lt;/span&gt;
    &lt;span class="text-muted-foreground"&gt;66%&lt;/span&gt;
&lt;/div&gt;
&lt;Progress Value="66" aria-label="File upload progress" /&gt;</code></pre>
    </section>
</div>
