@page "/components/toggle-group"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Toggle Group - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Toggle Group</h1>
        <p class="text-lg text-muted-foreground mt-2">A set of toggle buttons. Supports single and multiple selection modes.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Single</h2>
        <div class="rounded-lg border bg-card p-6">
            <ToggleGroup Type="ToggleGroupType.Single">
                <ToggleGroupItem ItemValue="bold" aria-label="Bold">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <path d="M6 12h9a4 4 0 0 1 0 8H7a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h7a4 4 0 0 1 0 8"/>
                    </svg>
                </ToggleGroupItem>
                <ToggleGroupItem ItemValue="italic" aria-label="Italic">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <line x1="19" x2="10" y1="4" y2="4"/><line x1="14" x2="5" y1="20" y2="20"/>
                        <line x1="15" x2="9" y1="4" y2="20"/>
                    </svg>
                </ToggleGroupItem>
                <ToggleGroupItem ItemValue="underline" aria-label="Underline">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <path d="M6 4v6a6 6 0 0 0 12 0V4"/><line x1="4" x2="20" y1="22" y2="22"/>
                    </svg>
                </ToggleGroupItem>
            </ToggleGroup>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;ToggleGroup Type="ToggleGroupType.Single"&gt;
    &lt;ToggleGroupItem ItemValue="bold" aria-label="Bold"&gt;B&lt;/ToggleGroupItem&gt;
    &lt;ToggleGroupItem ItemValue="italic" aria-label="Italic"&gt;I&lt;/ToggleGroupItem&gt;
    &lt;ToggleGroupItem ItemValue="underline" aria-label="Underline"&gt;U&lt;/ToggleGroupItem&gt;
&lt;/ToggleGroup&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Multiple</h2>
        <div class="rounded-lg border bg-card p-6">
            <ToggleGroup Type="ToggleGroupType.Multiple">
                <ToggleGroupItem ItemValue="bold" aria-label="Bold">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <path d="M6 12h9a4 4 0 0 1 0 8H7a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h7a4 4 0 0 1 0 8"/>
                    </svg>
                </ToggleGroupItem>
                <ToggleGroupItem ItemValue="italic" aria-label="Italic">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <line x1="19" x2="10" y1="4" y2="4"/><line x1="14" x2="5" y1="20" y2="20"/>
                        <line x1="15" x2="9" y1="4" y2="20"/>
                    </svg>
                </ToggleGroupItem>
                <ToggleGroupItem ItemValue="underline" aria-label="Underline">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                        <path d="M6 4v6a6 6 0 0 0 12 0V4"/><line x1="4" x2="20" y1="22" y2="22"/>
                    </svg>
                </ToggleGroupItem>
            </ToggleGroup>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;ToggleGroup Type="ToggleGroupType.Multiple"&gt;
    &lt;ToggleGroupItem ItemValue="bold" aria-label="Bold"&gt;B&lt;/ToggleGroupItem&gt;
    &lt;ToggleGroupItem ItemValue="italic" aria-label="Italic"&gt;I&lt;/ToggleGroupItem&gt;
    &lt;ToggleGroupItem ItemValue="underline" aria-label="Underline"&gt;U&lt;/ToggleGroupItem&gt;
&lt;/ToggleGroup&gt;</code></pre>
    </section>
</div>
