@page "/components/combobox"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Combobox - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Combobox</h1>
        <p class="text-lg text-muted-foreground mt-2">Searchable select — combines a trigger button with a filtered list of options.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Framework Selector</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="flex flex-wrap items-start gap-4">
                <div class="w-64 space-y-2">
                    <Combobox @bind-Value="_comboboxValue" Placeholder="Select framework...">
                        <ComboboxTrigger Class="w-full" />
                        <ComboboxContent>
                            <ComboboxInput />
                            <ComboboxItem ItemValue="next" FilterText="Next.js">Next.js</ComboboxItem>
                            <ComboboxItem ItemValue="sveltekit" FilterText="SvelteKit">SvelteKit</ComboboxItem>
                            <ComboboxItem ItemValue="nuxt" FilterText="Nuxt.js">Nuxt.js</ComboboxItem>
                            <ComboboxItem ItemValue="remix" FilterText="Remix">Remix</ComboboxItem>
                            <ComboboxItem ItemValue="astro" FilterText="Astro">Astro</ComboboxItem>
                        </ComboboxContent>
                    </Combobox>
                    @if (!string.IsNullOrEmpty(_comboboxValue))
                    {
                        <p class="text-sm text-muted-foreground">Selected: <span class="font-medium text-foreground">@_comboboxValue</span></p>
                    }
                </div>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml"><span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>Combobox</span> <span class="token attr-name">&#64;&#64;bind-Value</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>selectedFramework<span class="token punctuation">"</span></span> <span class="token attr-name">Placeholder</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Select framework...<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxTrigger</span> <span class="token attr-name">Class</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>w-64<span class="token punctuation">"</span></span> <span class="token punctuation">/></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxContent</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxInput</span> <span class="token punctuation">/></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxItem</span> <span class="token attr-name">ItemValue</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>next<span class="token punctuation">"</span></span> <span class="token attr-name">FilterText</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Next.js<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>Next.js<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>ComboboxItem</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxItem</span> <span class="token attr-name">ItemValue</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>sveltekit<span class="token punctuation">"</span></span> <span class="token attr-name">FilterText</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>SvelteKit<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>SvelteKit<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>ComboboxItem</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxItem</span> <span class="token attr-name">ItemValue</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>nuxt<span class="token punctuation">"</span></span> <span class="token attr-name">FilterText</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Nuxt.js<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>Nuxt.js<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>ComboboxItem</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxItem</span> <span class="token attr-name">ItemValue</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>remix<span class="token punctuation">"</span></span> <span class="token attr-name">FilterText</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Remix<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>Remix<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>ComboboxItem</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxItem</span> <span class="token attr-name">ItemValue</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>astro<span class="token punctuation">"</span></span> <span class="token attr-name">FilterText</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Astro<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>Astro<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>ComboboxItem</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>ComboboxContent</span><span class="token punctuation">></span></span>
<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>Combobox</span><span class="token punctuation">></span></span></code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Custom Search Placeholder</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="flex flex-wrap items-start gap-4">
                <Combobox Placeholder="Pick a framework..." SearchPlaceholder="Search frameworks...">
                    <ComboboxTrigger Class="w-64" />
                    <ComboboxContent>
                        <ComboboxInput />
                        <ComboboxItem ItemValue="next" FilterText="Next.js">Next.js</ComboboxItem>
                        <ComboboxItem ItemValue="sveltekit" FilterText="SvelteKit">SvelteKit</ComboboxItem>
                        <ComboboxItem ItemValue="nuxt" FilterText="Nuxt.js">Nuxt.js</ComboboxItem>
                    </ComboboxContent>
                </Combobox>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml"><span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>Combobox</span> <span class="token attr-name">Placeholder</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Pick a framework...<span class="token punctuation">"</span></span> <span class="token attr-name">SearchPlaceholder</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Search frameworks...<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxTrigger</span> <span class="token attr-name">Class</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>w-64<span class="token punctuation">"</span></span> <span class="token punctuation">/></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxContent</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxInput</span> <span class="token punctuation">/></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>ComboboxItem</span> <span class="token attr-name">ItemValue</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>next<span class="token punctuation">"</span></span> <span class="token attr-name">FilterText</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Next.js<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>Next.js<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>ComboboxItem</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>ComboboxContent</span><span class="token punctuation">></span></span>
<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>Combobox</span><span class="token punctuation">></span></span></code></pre>
    </section>
</div>

@code {
    private string? _comboboxValue;
}
