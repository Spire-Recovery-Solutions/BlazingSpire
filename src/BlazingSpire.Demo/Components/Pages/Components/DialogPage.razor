@page "/components/dialog"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Dialog - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Dialog</h1>
        <p class="text-lg text-muted-foreground mt-2">A modal dialog with focus trap, scroll lock, and click-outside/Escape dismissal.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Edit Profile</h2>
        <div class="rounded-lg border bg-card p-6">
            <Dialog>
                <DialogTrigger>
                    <Button Variant="ButtonVariant.Outline">Edit Profile</Button>
                </DialogTrigger>
                <DialogContent>
                    <DialogClose />
                    <DialogHeader>
                        <DialogTitle>Edit profile</DialogTitle>
                        <DialogDescription>Make changes to your profile here. Click save when you&#39;re done.</DialogDescription>
                    </DialogHeader>
                    <div class="grid gap-4 py-4">
                        <div class="grid grid-cols-4 items-center gap-4">
                            <Label For="name-demo" Class="text-right">Name</Label>
                            <Input id="name-demo" Value="Adam Reed" Class="col-span-3" />
                        </div>
                        <div class="grid grid-cols-4 items-center gap-4">
                            <Label For="username-demo" Class="text-right">Username</Label>
                            <Input id="username-demo" Value="@("@adamreed")" Class="col-span-3" />
                        </div>
                    </div>
                    <DialogFooter>
                        <Button>Save changes</Button>
                    </DialogFooter>
                </DialogContent>
            </Dialog>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Dialog&gt;
    &lt;DialogTrigger&gt;
        &lt;Button Variant="ButtonVariant.Outline"&gt;Edit Profile&lt;/Button&gt;
    &lt;/DialogTrigger&gt;
    &lt;DialogContent&gt;
        &lt;DialogClose /&gt;
        &lt;DialogHeader&gt;
            &lt;DialogTitle&gt;Edit profile&lt;/DialogTitle&gt;
            &lt;DialogDescription&gt;Make changes to your profile here.&lt;/DialogDescription&gt;
        &lt;/DialogHeader&gt;
        &lt;div class="grid gap-4 py-4"&gt;
            &lt;div class="grid grid-cols-4 items-center gap-4"&gt;
                &lt;Label For="name" Class="text-right"&gt;Name&lt;/Label&gt;
                &lt;Input id="name" Value="Adam Reed" Class="col-span-3" /&gt;
            &lt;/div&gt;
            &lt;div class="grid grid-cols-4 items-center gap-4"&gt;
                &lt;Label For="username" Class="text-right"&gt;Username&lt;/Label&gt;
                &lt;Input id="username" Value="&#64;adamreed" Class="col-span-3" /&gt;
            &lt;/div&gt;
        &lt;/div&gt;
        &lt;DialogFooter&gt;
            &lt;Button&gt;Save changes&lt;/Button&gt;
        &lt;/DialogFooter&gt;
    &lt;/DialogContent&gt;
&lt;/Dialog&gt;</code></pre>
    </section>
</div>
