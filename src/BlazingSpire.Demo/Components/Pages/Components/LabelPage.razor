@page "/components/label"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Label - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Label</h1>
        <p class="text-lg text-muted-foreground mt-2">A styled label element for form fields.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Basic</h2>
        <div class="rounded-lg border bg-card p-6">
            <Label>Email address</Label>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Label&gt;Email address&lt;/Label&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">With For Attribute</h2>
        <div class="rounded-lg border bg-card p-6">
            <Label For="email">Email address</Label>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Label For="email"&gt;Email address&lt;/Label&gt;</code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Custom Styling</h2>
        <div class="rounded-lg border bg-card p-6">
            <Label Class="text-primary">Required field</Label>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;Label Class="text-primary"&gt;Required field&lt;/Label&gt;</code></pre>
    </section>
</div>
