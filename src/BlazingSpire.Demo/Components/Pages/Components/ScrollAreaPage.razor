@page "/components/scroll-area"
@using BlazingSpire.Demo.Components.UI

<PageTitle>ScrollArea - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">ScrollArea</h1>
        <p class="text-lg text-muted-foreground mt-2">A styled scrollable container with hidden overflow and a full-height inner scroll viewport.</p>
    </div>

    @* ── Basic ─────────────────────── *@
    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Basic</h2>
        <div class="rounded-lg border bg-card p-6">
            <ScrollArea Class="h-72 w-48 rounded-md border">
                <div class="p-4">
                    <h4 class="mb-4 text-sm font-medium leading-none">Tags</h4>
                    @foreach (var tag in _scrollTags)
                    {
                        <div class="text-sm py-1 border-b border-border last:border-0">@tag</div>
                    }
                </div>
            </ScrollArea>
        </div>
        <pre class="language-xml"><code class="language-xml">&lt;ScrollArea Class="h-72 w-48 rounded-md border"&gt;
    &lt;div class="p-4"&gt;
        &lt;h4 class="mb-4 text-sm font-medium leading-none"&gt;Tags&lt;/h4&gt;
        @@foreach (var tag in tags)
        &#123;
            &lt;div class="text-sm py-1 border-b border-border last:border-0"&gt;@@tag&lt;/div&gt;
        &#125;
    &lt;/div&gt;
&lt;/ScrollArea&gt;</code></pre>
    </section>
</div>

@code {
    private static readonly string[] _scrollTags =
    [
        "v1.2.0-beta.1", "v1.1.4", "v1.1.3", "v1.1.2", "v1.1.1",
        "v1.1.0", "v1.0.4", "v1.0.3", "v1.0.2", "v1.0.1",
        "v1.0.0", "v0.9.0", "v0.8.2", "v0.8.1", "v0.8.0",
        "v0.7.0", "v0.6.0", "v0.5.0", "v0.4.0", "v0.3.0",
    ];
}
