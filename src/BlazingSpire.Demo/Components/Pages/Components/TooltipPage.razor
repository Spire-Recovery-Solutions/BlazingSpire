@page "/components/tooltip"
@using BlazingSpire.Demo.Components.UI
@using BlazingSpire.Demo.Components.Shared

<PageTitle>Tooltip - BlazingSpire</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-3xl font-bold tracking-tight">Tooltip</h1>
        <p class="text-lg text-muted-foreground mt-2">Floating label that appears on hover. Supports delay, sides, and alignment.</p>
    </div>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Basic</h2>
        <div class="rounded-lg border bg-card p-6">
            <TooltipProvider>
                <Tooltip>
                    <TooltipTrigger>
                        <Button Variant="ButtonVariant.Outline">Hover me</Button>
                    </TooltipTrigger>
                    <TooltipContent>Add to library</TooltipContent>
                </Tooltip>
            </TooltipProvider>
        </div>
        <pre class="language-xml"><code class="language-xml"><span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>TooltipProvider</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>Tooltip</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>TooltipTrigger</span><span class="token punctuation">></span></span>
            <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>Button</span> <span class="token attr-name">Variant</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>ButtonVariant.Outline<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>Hover me<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>Button</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>TooltipTrigger</span><span class="token punctuation">></span></span>
        <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>TooltipContent</span><span class="token punctuation">></span></span>Add to library<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>TooltipContent</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>Tooltip</span><span class="token punctuation">></span></span>
<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>TooltipProvider</span><span class="token punctuation">></span></span></code></pre>
    </section>

    <section class="space-y-4">
        <h2 class="text-xl font-semibold tracking-tight">Sides</h2>
        <div class="rounded-lg border bg-card p-6">
            <div class="flex flex-wrap items-center gap-6">
                <TooltipProvider>
                    <Tooltip Side="FloatingSide.Top">
                        <TooltipTrigger><Button Variant="ButtonVariant.Outline">Top</Button></TooltipTrigger>
                        <TooltipContent>Tooltip on top</TooltipContent>
                    </Tooltip>
                    <Tooltip Side="FloatingSide.Bottom">
                        <TooltipTrigger><Button Variant="ButtonVariant.Outline">Bottom</Button></TooltipTrigger>
                        <TooltipContent>Tooltip on bottom</TooltipContent>
                    </Tooltip>
                    <Tooltip Side="FloatingSide.Left">
                        <TooltipTrigger><Button Variant="ButtonVariant.Outline">Left</Button></TooltipTrigger>
                        <TooltipContent>Tooltip on left</TooltipContent>
                    </Tooltip>
                    <Tooltip Side="FloatingSide.Right">
                        <TooltipTrigger><Button Variant="ButtonVariant.Outline">Right</Button></TooltipTrigger>
                        <TooltipContent>Tooltip on right</TooltipContent>
                    </Tooltip>
                </TooltipProvider>
            </div>
        </div>
        <pre class="language-xml"><code class="language-xml"><span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>TooltipProvider</span><span class="token punctuation">></span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>Tooltip</span> <span class="token attr-name">Side</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>FloatingSide.Top<span class="token punctuation">"</span></span><span class="token punctuation">></span></span>
