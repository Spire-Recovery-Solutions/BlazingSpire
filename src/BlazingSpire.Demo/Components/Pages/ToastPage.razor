@page "/components/toast"
@using BlazingSpire.Demo.Components.UI
@inject IToastService ToastService

<PageTitle>Toast - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Toast</h1>
        <p class="text-lg text-muted-foreground">Brief notification messages that appear and auto-dismiss.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Button @onclick="ShowDefault">Show Toast</Button>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">@@inject IToastService ToastService

&lt;Button &#64;onclick=&quot;ShowToast&quot;&gt;Show Toast&lt;/Button&gt;

@@code {
    private void ShowToast()
    {
        ToastService.Show(&quot;Scheduled: Catch up&quot;, &quot;Friday, February 10, 2023 at 5:57 PM&quot;);
    }
}</code></pre>
    </div>

    @* ── Variants ───────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Variants</h2>
        <div class="flex flex-wrap items-center gap-4 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Default</span>
                <Button Variant="ButtonVariant.Outline" @onclick="ShowDefault">Default</Button>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">With Description</span>
                <Button Variant="ButtonVariant.Outline" @onclick="ShowWithDescription">With Description</Button>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Destructive</span>
                <Button Variant="ButtonVariant.Outline" @onclick="ShowDestructive">Destructive</Button>
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">With Action</span>
                <Button Variant="ButtonVariant.Outline" @onclick="ShowWithAction">With Action</Button>
            </div>
        </div>
    </div>

</div>

@code {
    private void ShowDefault() =>
        ToastService.Show("Event has been created.");

    private void ShowWithDescription() =>
        ToastService.Show("Scheduled: Catch up", "Friday, February 10, 2023 at 5:57 PM");

    private void ShowDestructive() =>
        ToastService.Show("Uh oh! Something went wrong.", "There was a problem with your request.", ToastVariant.Destructive);

    private void ShowWithAction() =>
        ToastService.Show(new ToastMessage(
            "Undo action",
            "Your changes have been saved.",
            ActionLabel: "Undo",
            OnAction: () => ToastService.Show("Action undone.")));
}
