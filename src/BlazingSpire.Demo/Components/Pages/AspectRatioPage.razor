@page "/components/aspect-ratio"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Aspect Ratio - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Aspect Ratio</h1>
        <p class="text-lg text-muted-foreground">Displays content within a desired ratio, maintaining proportions.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-[300px]">
                <AspectRatio Ratio="16.0 / 9.0" Class="bg-muted rounded-md overflow-hidden">
                    <div class="flex h-full w-full items-center justify-center text-sm text-muted-foreground">
                        16 / 9
                    </div>
                </AspectRatio>
            </div>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;AspectRatio Ratio=&quot;16.0 / 9.0&quot;&gt;
    &lt;img src=&quot;photo.jpg&quot; alt=&quot;Photo&quot; class=&quot;h-full w-full object-cover&quot; /&gt;
&lt;/AspectRatio&gt;</code></pre>
    </div>

    @* ── Common Ratios ───────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Common Ratios</h2>
        <div class="flex flex-wrap items-start gap-6 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">16:9</span>
                <div class="w-[180px]">
                    <AspectRatio Ratio="16.0 / 9.0" Class="bg-muted rounded-md overflow-hidden">
                        <div class="flex h-full w-full items-center justify-center text-xs text-muted-foreground">16:9</div>
                    </AspectRatio>
                </div>
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">4:3</span>
                <div class="w-[160px]">
                    <AspectRatio Ratio="4.0 / 3.0" Class="bg-muted rounded-md overflow-hidden">
                        <div class="flex h-full w-full items-center justify-center text-xs text-muted-foreground">4:3</div>
                    </AspectRatio>
                </div>
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">1:1</span>
                <div class="w-[120px]">
                    <AspectRatio Ratio="1.0" Class="bg-muted rounded-md overflow-hidden">
                        <div class="flex h-full w-full items-center justify-center text-xs text-muted-foreground">1:1</div>
                    </AspectRatio>
                </div>
            </div>
        </div>
    </div>

</div>
