@page "/components/form-section"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Form Section - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Form Section</h1>
        <p class="text-lg text-muted-foreground">A fieldset wrapper that groups related form fields with a legend and description.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-full max-w-sm">
                <FormSection Legend="Personal Information" Description="Enter your personal details below.">
                    <div class="mt-4 space-y-4">
                        <FormField Name="name">
                            <FormFieldLabel>Full name</FormFieldLabel>
                            <FormFieldControl>
                                <Input Placeholder="Jane Doe" />
                            </FormFieldControl>
                        </FormField>
                        <FormField Name="email-section">
                            <FormFieldLabel>Email</FormFieldLabel>
                            <FormFieldControl>
                                <Input Type="email" Placeholder="jane@example.com" />
                            </FormFieldControl>
                        </FormField>
                    </div>
                </FormSection>
            </div>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;FormSection Legend=&quot;Personal Information&quot; Description=&quot;Enter your personal details below.&quot;&gt;
    &lt;div class=&quot;mt-4 space-y-4&quot;&gt;
        &lt;FormField Name=&quot;name&quot;&gt;
            &lt;FormFieldLabel&gt;Full name&lt;/FormFieldLabel&gt;
            &lt;FormFieldControl&gt;
                &lt;Input Placeholder=&quot;Jane Doe&quot; /&gt;
            &lt;/FormFieldControl&gt;
        &lt;/FormField&gt;
        &lt;FormField Name=&quot;email&quot;&gt;
            &lt;FormFieldLabel&gt;Email&lt;/FormFieldLabel&gt;
            &lt;FormFieldControl&gt;
                &lt;Input Type=&quot;email&quot; Placeholder=&quot;jane@@example.com&quot; /&gt;
            &lt;/FormFieldControl&gt;
        &lt;/FormField&gt;
    &lt;/div&gt;
&lt;/FormSection&gt;</code></pre>
    </div>

    @* ── Disabled ───────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Disabled</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-full max-w-sm">
                <FormSection Legend="Account Settings" Description="These settings are currently locked." Disabled="true">
                    <div class="mt-4 space-y-4">
                        <FormField Name="username-disabled">
                            <FormFieldLabel>Username</FormFieldLabel>
                            <FormFieldControl>
                                <Input Placeholder="username" />
                            </FormFieldControl>
                        </FormField>
                        <FormField Name="password-disabled">
                            <FormFieldLabel>Password</FormFieldLabel>
                            <FormFieldControl>
                                <Input Type="password" Placeholder="••••••••" />
                            </FormFieldControl>
                        </FormField>
                    </div>
                </FormSection>
            </div>
        </div>
    </div>

</div>
