@page "/components/command"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Command - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Command</h1>
        <p class="text-lg text-muted-foreground">A fast, keyboard-friendly command palette with grouped, searchable items.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-full max-w-sm rounded-lg border shadow-md">
                <Command>
                    <CommandInput Placeholder="Type a command or search..." />
                    <CommandList>
                        <CommandGroup Heading="Suggestions">
                            <CommandItem FilterText="Calendar">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                     class="mr-2 h-4 w-4" aria-hidden="true">
                                    <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
                                    <line x1="16" x2="16" y1="2" y2="6"/>
                                    <line x1="8" x2="8" y1="2" y2="6"/>
                                    <line x1="3" x2="21" y1="10" y2="10"/>
                                </svg>
                                Calendar
                            </CommandItem>
                            <CommandItem FilterText="Search Emoji">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                     class="mr-2 h-4 w-4" aria-hidden="true">
                                    <circle cx="11" cy="11" r="8"/>
                                    <path d="m21 21-4.3-4.3"/>
                                </svg>
                                Search Emoji
                            </CommandItem>
                            <CommandItem FilterText="Calculator">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                     class="mr-2 h-4 w-4" aria-hidden="true">
                                    <rect width="16" height="20" x="4" y="2" rx="2"/>
                                    <line x1="8" x2="16" y1="6" y2="6"/>
                                    <line x1="8" x2="8" y1="14" y2="18"/>
                                    <line x1="12" x2="12" y1="14" y2="18"/>
                                    <line x1="16" x2="16" y1="14" y2="18"/>
                                    <line x1="8" x2="16" y1="10" y2="10"/>
                                </svg>
                                Calculator
                            </CommandItem>
                        </CommandGroup>
                        <CommandSeparator />
                        <CommandGroup Heading="Settings">
                            <CommandItem FilterText="Profile">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                     class="mr-2 h-4 w-4" aria-hidden="true">
                                    <circle cx="12" cy="8" r="4"/>
                                    <path d="M20 21a8 8 0 0 0-16 0"/>
                                </svg>
                                Profile
                            </CommandItem>
                            <CommandItem FilterText="Billing">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                     class="mr-2 h-4 w-4" aria-hidden="true">
                                    <rect width="20" height="14" x="2" y="5" rx="2"/>
                                    <line x1="2" x2="22" y1="10" y2="10"/>
                                </svg>
                                Billing
                            </CommandItem>
                        </CommandGroup>
                        <CommandEmpty>No results found.</CommandEmpty>
                    </CommandList>
                </Command>
            </div>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Command&gt;
    &lt;CommandInput Placeholder=&quot;Type a command or search...&quot; /&gt;
    &lt;CommandList&gt;
        &lt;CommandGroup Heading=&quot;Suggestions&quot;&gt;
            &lt;CommandItem FilterText=&quot;Calendar&quot;&gt;Calendar&lt;/CommandItem&gt;
            &lt;CommandItem FilterText=&quot;Search Emoji&quot;&gt;Search Emoji&lt;/CommandItem&gt;
            &lt;CommandItem FilterText=&quot;Calculator&quot;&gt;Calculator&lt;/CommandItem&gt;
        &lt;/CommandGroup&gt;
        &lt;CommandSeparator /&gt;
        &lt;CommandGroup Heading=&quot;Settings&quot;&gt;
            &lt;CommandItem FilterText=&quot;Profile&quot;&gt;Profile&lt;/CommandItem&gt;
            &lt;CommandItem FilterText=&quot;Billing&quot;&gt;Billing&lt;/CommandItem&gt;
        &lt;/CommandGroup&gt;
        &lt;CommandEmpty&gt;No results found.&lt;/CommandEmpty&gt;
    &lt;/CommandList&gt;
&lt;/Command&gt;</code></pre>
    </div>

</div>
