@page "/components/input"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Input - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Input</h1>
        <p class="text-lg text-muted-foreground">A text input field for user data entry.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Input class="max-w-sm" Placeholder="Enter your email" @bind-value="_value" />
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Input Placeholder=&quot;Enter your email&quot; /&gt;</code></pre>
    </div>

    @* ── Examples ───────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Examples</h2>
        <div class="grid gap-4 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Default</span>
                <Input class="max-w-sm" Placeholder="Text input" />
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Password</span>
                <Input class="max-w-sm" Type="password" Placeholder="Enter password" />
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">File</span>
                <Input class="max-w-sm" Type="file" />
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Disabled</span>
                <Input class="max-w-sm" Placeholder="Disabled input" Disabled="true" />
            </div>
        </div>
    </div>

</div>

@code {
    private string _value = "";
}
