@page "/components/scroll-area"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Scroll Area - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Scroll Area</h1>
        <p class="text-lg text-muted-foreground">A scrollable container with consistent cross-browser styling.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <ScrollArea Class="h-64 w-72 rounded-md border">
                <div class="p-4 space-y-2">
                    <h4 class="text-sm font-semibold">Tags</h4>
                    @foreach (var tag in _tags)
                    {
                        <div class="rounded-md border px-3 py-2 text-sm">@tag</div>
                    }
                </div>
            </ScrollArea>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;ScrollArea Class=&quot;h-64 w-72 rounded-md border&quot;&gt;
    &lt;div class=&quot;p-4 space-y-2&quot;&gt;
        &lt;h4 class=&quot;text-sm font-semibold&quot;&gt;Tags&lt;/h4&gt;
        @@foreach (var tag in tags)
        {
            &lt;div class=&quot;rounded-md border px-3 py-2 text-sm&quot;&gt;@@tag&lt;/div&gt;
        }
    &lt;/div&gt;
&lt;/ScrollArea&gt;</code></pre>
    </div>

    @* ── Horizontal ──────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Horizontal</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <ScrollArea Class="w-96 rounded-md border">
                <div class="flex gap-4 p-4">
                    @for (int i = 1; i <= 10; i++)
                    {
                        <div class="shrink-0 rounded-md border p-4 text-sm font-medium w-32 text-center">
                            Item @i
                        </div>
                    }
                </div>
            </ScrollArea>
        </div>
    </div>

</div>

@code {
    private static readonly string[] _tags =
    [
        "Accessibility", "Animation", "Badge", "Button", "Calendar",
        "Card", "Checkbox", "Collapsible", "Command", "Dialog",
        "Dropdown Menu", "Form", "Input", "Label", "Navigation",
        "Pagination", "Popover", "Progress", "Select", "Separator",
        "Sheet", "Sidebar", "Skeleton", "Slider", "Switch",
        "Table", "Tabs", "Textarea", "Toast", "Toggle"
    ];
}
