@page "/components/label"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Label - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Label</h1>
        <p class="text-lg text-muted-foreground">Renders an accessible label associated with a form control.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="flex items-center gap-2">
                <input type="checkbox" id="label-demo" class="h-4 w-4 rounded border-input" />
                <Label For="label-demo">Accept terms and conditions</Label>
            </div>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Label For=&quot;email&quot;&gt;Email&lt;/Label&gt;
&lt;Input id=&quot;email&quot; Placeholder=&quot;Enter your email&quot; /&gt;</code></pre>
    </div>

    @* ── With Input ─────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">With Input</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="grid w-full max-w-sm gap-1.5">
                <Label For="email-demo">Email</Label>
                <Input id="email-demo" Type="email" Placeholder="Enter your email" />
            </div>
        </div>
    </div>

</div>
