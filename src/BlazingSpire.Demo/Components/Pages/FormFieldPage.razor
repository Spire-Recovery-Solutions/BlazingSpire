@page "/components/form-field"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Form Field - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Form Field</h1>
        <p class="text-lg text-muted-foreground">Composes a label, input, description, and error message into a single form field.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-full max-w-sm">
                <FormField Name="username">
                    <FormFieldLabel>Username</FormFieldLabel>
                    <FormFieldControl>
                        <Input Placeholder="Enter username" />
                    </FormFieldControl>
                    <FormFieldDescription>This is your public display name.</FormFieldDescription>
                </FormField>
            </div>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;FormField Name=&quot;username&quot;&gt;
    &lt;FormFieldLabel&gt;Username&lt;/FormFieldLabel&gt;
    &lt;FormFieldControl&gt;
        &lt;Input Placeholder=&quot;Enter username&quot; /&gt;
    &lt;/FormFieldControl&gt;
    &lt;FormFieldDescription&gt;This is your public display name.&lt;/FormFieldDescription&gt;
&lt;/FormField&gt;</code></pre>
    </div>

    @* ── With error ─────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">With Error</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-full max-w-sm">
                <FormField Name="email" ErrorMessage="@_errorMessage">
                    <FormFieldLabel>Email</FormFieldLabel>
                    <FormFieldControl>
                        <Input Type="email" Placeholder="Enter email" @bind-value="_email" />
                    </FormFieldControl>
                    <FormFieldDescription>We'll never share your email.</FormFieldDescription>
                    <FormFieldError />
                </FormField>
                <div class="mt-4 flex gap-2">
                    <Button Variant="ButtonVariant.Outline" @onclick="ClearError">Clear error</Button>
                    <Button @onclick="ShowError">Show error</Button>
                </div>
            </div>
        </div>
    </div>

    @* ── Complete form composition ──────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Complete Form</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-full max-w-sm space-y-4">
                <FormField Name="first-name">
                    <FormFieldLabel>First name</FormFieldLabel>
                    <FormFieldControl>
                        <Input Placeholder="John" />
                    </FormFieldControl>
                </FormField>
                <FormField Name="last-name">
                    <FormFieldLabel>Last name</FormFieldLabel>
                    <FormFieldControl>
                        <Input Placeholder="Doe" />
                    </FormFieldControl>
                </FormField>
                <FormField Name="bio">
                    <FormFieldLabel>Bio</FormFieldLabel>
                    <FormFieldControl>
                        <Textarea Placeholder="Tell us about yourself." />
                    </FormFieldControl>
                    <FormFieldDescription>Up to 200 characters.</FormFieldDescription>
                </FormField>
                <Button>Submit</Button>
            </div>
        </div>
    </div>

</div>

@code {
    private string _email = "";
    private string? _errorMessage;

    private void ShowError() => _errorMessage = "Please enter a valid email address.";
    private void ClearError() => _errorMessage = null;
}
