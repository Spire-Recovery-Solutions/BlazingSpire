@page "/components/checkbox"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Checkbox - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Checkbox</h1>
        <p class="text-lg text-muted-foreground">A control that can be checked or unchecked.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="flex items-center gap-2">
                <Checkbox @bind-Checked="_checked" />
                <Label>Accept terms and conditions</Label>
            </div>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;div class=&quot;flex items-center gap-2&quot;&gt;
    &lt;Checkbox &#64;bind-Checked=&quot;_checked&quot; /&gt;
    &lt;Label&gt;Accept terms and conditions&lt;/Label&gt;
&lt;/div&gt;

@@code {
    private bool _checked;
}</code></pre>
    </div>

    @* ── Examples ───────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Examples</h2>
        <div class="flex flex-wrap items-center gap-8 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Unchecked</span>
                <Checkbox />
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Checked</span>
                <Checkbox Checked="true" />
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Disabled</span>
                <Checkbox Disabled="true" />
            </div>
            <div class="flex flex-col items-center gap-2">
                <span class="text-xs text-muted-foreground">Disabled checked</span>
                <Checkbox Checked="true" Disabled="true" />
            </div>
        </div>
    </div>

</div>

@code {
    private bool _checked;
}
