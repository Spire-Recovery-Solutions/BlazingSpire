@page "/components/calendar"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Calendar - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Calendar</h1>
        <p class="text-lg text-muted-foreground">A date picker calendar for selecting a single date.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex flex-col items-center gap-4 rounded-xl border bg-muted/30 p-8">
            <div class="rounded-md border bg-background shadow-sm">
                <Calendar @bind-SelectedDate="_selectedDate" />
            </div>
            @if (_selectedDate.HasValue)
            {
                <p class="text-sm text-muted-foreground">Selected: <span class="font-medium text-foreground">@_selectedDate.Value.ToString("MMMM d, yyyy")</span></p>
            }
            else
            {
                <p class="text-sm text-muted-foreground">No date selected.</p>
            }
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Calendar &#64;bind-SelectedDate=&quot;_selectedDate&quot; /&gt;

@@code {
    private DateOnly? _selectedDate;
}</code></pre>
    </div>

</div>

@code {
    private DateOnly? _selectedDate;
}
