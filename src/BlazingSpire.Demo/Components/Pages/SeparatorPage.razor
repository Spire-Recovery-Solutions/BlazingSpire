@page "/components/separator"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Separator - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Separator</h1>
        <p class="text-lg text-muted-foreground">Visually or semantically separates content.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <div class="w-full max-w-md space-y-4">
                <div>
                    <h4 class="text-sm font-medium">BlazingSpire</h4>
                    <p class="text-sm text-muted-foreground">A Blazor component library.</p>
                </div>
                <Separator />
                <div class="flex gap-4 text-sm">
                    <span>Blog</span>
                    <Separator Orientation="SeparatorOrientation.Vertical" Class="h-5" />
                    <span>Docs</span>
                    <Separator Orientation="SeparatorOrientation.Vertical" Class="h-5" />
                    <span>Source</span>
                </div>
            </div>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Separator /&gt;

&lt;Separator Orientation=&quot;SeparatorOrientation.Vertical&quot; /&gt;</code></pre>
    </div>

    @* ── Orientations ───────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Orientations</h2>
        <div class="flex flex-wrap items-start gap-8 rounded-xl border bg-muted/30 p-8">
            <div class="flex flex-col gap-2 w-48">
                <span class="text-xs text-muted-foreground">Horizontal</span>
                <Separator />
            </div>
            <div class="flex flex-col gap-2">
                <span class="text-xs text-muted-foreground">Vertical</span>
                <div class="flex items-center gap-4 h-8">
                    <span class="text-sm">Left</span>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <span class="text-sm">Right</span>
                </div>
            </div>
        </div>
    </div>

</div>
