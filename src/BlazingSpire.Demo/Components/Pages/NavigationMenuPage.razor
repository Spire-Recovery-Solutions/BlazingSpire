@page "/components/navigation-menu"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Navigation Menu - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Navigation Menu</h1>
        <p class="text-lg text-muted-foreground">A top-level navigation menu with expandable content panels.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-start justify-center rounded-xl border bg-muted/30 p-8 min-h-48">
            <NavigationMenu>
                <NavigationMenuList>
                    <NavigationMenuItem>
                        <NavigationMenuTrigger>Getting Started</NavigationMenuTrigger>
                        <NavigationMenuContent>
                            <div class="grid gap-2 w-64">
                                <NavigationMenuLink Href="/components/button">
                                    <div class="font-medium text-sm">Button</div>
                                    <div class="text-xs text-muted-foreground">Triggers an action when clicked.</div>
                                </NavigationMenuLink>
                                <NavigationMenuLink Href="/components/badge">
                                    <div class="font-medium text-sm">Badge</div>
                                    <div class="text-xs text-muted-foreground">Displays a status indicator.</div>
                                </NavigationMenuLink>
                                <NavigationMenuLink Href="/components/card">
                                    <div class="font-medium text-sm">Card</div>
                                    <div class="text-xs text-muted-foreground">A container for grouped content.</div>
                                </NavigationMenuLink>
                            </div>
                        </NavigationMenuContent>
                    </NavigationMenuItem>
                    <NavigationMenuItem>
                        <NavigationMenuTrigger>Components</NavigationMenuTrigger>
                        <NavigationMenuContent>
                            <div class="grid gap-2 w-64">
                                <NavigationMenuLink Href="/components/dialog">
                                    <div class="font-medium text-sm">Dialog</div>
                                    <div class="text-xs text-muted-foreground">A modal window overlay.</div>
                                </NavigationMenuLink>
                                <NavigationMenuLink Href="/components/dropdown-menu">
                                    <div class="font-medium text-sm">Dropdown Menu</div>
                                    <div class="text-xs text-muted-foreground">A menu triggered by a button.</div>
                                </NavigationMenuLink>
                            </div>
                        </NavigationMenuContent>
                    </NavigationMenuItem>
                    <NavigationMenuItem>
                        <NavigationMenuLink Href="/">
                            Home
                        </NavigationMenuLink>
                    </NavigationMenuItem>
                </NavigationMenuList>
            </NavigationMenu>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;NavigationMenu&gt;
    &lt;NavigationMenuList&gt;
        &lt;NavigationMenuItem&gt;
            &lt;NavigationMenuTrigger&gt;Getting Started&lt;/NavigationMenuTrigger&gt;
            &lt;NavigationMenuContent&gt;
                &lt;div class=&quot;grid gap-2 w-64&quot;&gt;
                    &lt;NavigationMenuLink Href=&quot;/components/button&quot;&gt;
                        &lt;div class=&quot;font-medium text-sm&quot;&gt;Button&lt;/div&gt;
                        &lt;div class=&quot;text-xs text-muted-foreground&quot;&gt;Triggers an action when clicked.&lt;/div&gt;
                    &lt;/NavigationMenuLink&gt;
                &lt;/div&gt;
            &lt;/NavigationMenuContent&gt;
        &lt;/NavigationMenuItem&gt;
        &lt;NavigationMenuItem&gt;
            &lt;NavigationMenuLink Href=&quot;/&quot;&gt;Home&lt;/NavigationMenuLink&gt;
        &lt;/NavigationMenuItem&gt;
    &lt;/NavigationMenuList&gt;
&lt;/NavigationMenu&gt;</code></pre>
    </div>

</div>
