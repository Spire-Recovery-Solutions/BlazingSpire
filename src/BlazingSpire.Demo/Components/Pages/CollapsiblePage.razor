@page "/components/collapsible"
@using BlazingSpire.Demo.Components.UI

<PageTitle>Collapsible - BlazingSpire</PageTitle>

<div class="space-y-8">

    @* ── Header ─────────────────────────────── *@
    <div class="space-y-1">
        <h1 class="text-3xl font-bold tracking-tight">Collapsible</h1>
        <p class="text-lg text-muted-foreground">An interactive component that expands and collapses content.</p>
    </div>

    @* ── Preview ────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Preview</h2>
        <div class="flex items-center justify-center rounded-xl border bg-muted/30 p-8">
            <Collapsible @bind-IsOpen="_isOpen" Class="w-full max-w-sm">
                <div class="flex items-center justify-between">
                    <h4 class="text-sm font-semibold">Starred repositories</h4>
                    <CollapsibleTrigger>
                        <Button Variant="ButtonVariant.Ghost" Class="h-9 w-9 p-0">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                                <path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/>
                            </svg>
                        </Button>
                    </CollapsibleTrigger>
                </div>
                <div class="rounded-md border px-4 py-3 font-mono text-sm">
                    blazingspire/ui
                </div>
                <CollapsibleContent>
                    <div class="rounded-md border px-4 py-3 font-mono text-sm">
                        blazingspire/icons
                    </div>
                    <div class="rounded-md border px-4 py-3 font-mono text-sm">
                        blazingspire/charts
                    </div>
                </CollapsibleContent>
            </Collapsible>
        </div>
    </div>

    @* ── Code ───────────────────────────────── *@
    <div class="space-y-3">
        <h2 class="text-xl font-semibold tracking-tight">Code</h2>
        <pre class="language-xml"><code class="language-xml">&lt;Collapsible &#64;bind-IsOpen=&quot;_isOpen&quot;&gt;
    &lt;div class=&quot;flex items-center justify-between&quot;&gt;
        &lt;h4 class=&quot;text-sm font-semibold&quot;&gt;Starred repositories&lt;/h4&gt;
        &lt;CollapsibleTrigger&gt;
            &lt;Button Variant=&quot;ButtonVariant.Ghost&quot; Class=&quot;h-9 w-9 p-0&quot;&gt;Toggle&lt;/Button&gt;
        &lt;/CollapsibleTrigger&gt;
    &lt;/div&gt;
    &lt;div class=&quot;rounded-md border px-4 py-3 font-mono text-sm&quot;&gt;
        blazingspire/ui
    &lt;/div&gt;
    &lt;CollapsibleContent&gt;
        &lt;div class=&quot;rounded-md border px-4 py-3 font-mono text-sm&quot;&gt;
            blazingspire/icons
        &lt;/div&gt;
        &lt;div class=&quot;rounded-md border px-4 py-3 font-mono text-sm&quot;&gt;
            blazingspire/charts
        &lt;/div&gt;
    &lt;/CollapsibleContent&gt;
&lt;/Collapsible&gt;

@@code {
    private bool _isOpen;
}</code></pre>
    </div>

</div>

@code {
    private bool _isOpen;
}
