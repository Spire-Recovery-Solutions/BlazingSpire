@inherits LayoutComponentBase
@using BlazingSpire.Demo.Components.UI

<ToastProvider />
<DialogProvider />
<div class="min-h-screen bg-background">

    @* ── Header ──────────────────────────────────────────── *@
    <header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
        <nav aria-label="Main navigation" class="flex h-14 items-center px-4 md:px-6">
            <button class="mr-2 inline-flex h-10 w-10 items-center justify-center rounded-md hover:bg-accent hover:text-accent-foreground md:hidden"
                    @onclick="ToggleMobileMenu" aria-label="Toggle menu">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                    @if (_mobileMenuOpen)
                    {
                        <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                    }
                    else
                    {
                        <line x1="4" x2="20" y1="6" y2="6"/>
                        <line x1="4" x2="20" y1="12" y2="12"/>
                        <line x1="4" x2="20" y1="18" y2="18"/>
                    }
                </svg>
            </button>
            <a href="/" class="flex items-center gap-2 font-semibold text-foreground no-underline">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-primary"
                     aria-hidden="true">
                    <path d="m13 2 7 7-7 7"/><path d="m6 9 4 4-4 4"/>
                </svg>
                <span>BlazingSpire</span>
            </a>
            <div class="ml-auto flex items-center gap-1">
                <a href="https://github.com/Spire-Recovery-Solutions/BlazingSpire" target="_blank" rel="noopener noreferrer"
                   class="inline-flex h-10 w-10 items-center justify-center rounded-md hover:bg-accent hover:text-accent-foreground"
                   aria-label="GitHub">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                        <path d="M9 18c-4.51 2-5-2-7-2"/>
                    </svg>
                </a>
                <ThemeToggle />
            </div>
        </nav>
    </header>

    <div class="flex">
        @* ── Sidebar (desktop) ───────────────────────────── *@
        <aside class="hidden md:block w-64 shrink-0 border-r bg-background">
            <div class="sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto">
                <DocsSidebar />
            </div>
        </aside>

        @* ── Mobile sidebar overlay ──────────────────────── *@
        @if (_mobileMenuOpen)
        {
            <div class="fixed inset-0 z-40 md:hidden" @onclick="CloseMobileMenu">
                <div class="fixed inset-0 bg-black/50"></div>
                <aside class="fixed inset-y-0 left-0 z-50 w-72 border-r bg-background pt-14 overflow-y-auto"
                       @onclick:stopPropagation="true">
                    <DocsSidebar OnNavigated="CloseMobileMenu" />
                </aside>
            </div>
        }

        @* ── Main content ────────────────────────────────── *@
        <main class="flex-1 min-w-0">
            <div class="mx-auto max-w-3xl px-6 py-10">
                @Body
            </div>
        </main>
    </div>
</div>

@code {
    private bool _mobileMenuOpen;

    private void ToggleMobileMenu() => _mobileMenuOpen = !_mobileMenuOpen;
    private void CloseMobileMenu() => _mobileMenuOpen = false;
}
