@namespace BlazingSpire.Demo.Components.UI
@inherits BlazingSpire.Demo.Components.Shared.BlazingSpireComponentBase

<button type="button" role="radio" aria-checked="@IsSelected.ToString().ToLowerInvariant()" data-state="@DataState"
        disabled="@Disabled" class="@Classes" @onclick="SelectAsync" @attributes="AdditionalAttributes">
    @if (IsSelected)
    {
        <span class="flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-2.5 w-2.5">
                <circle cx="12" cy="12" r="6"/>
            </svg>
        </span>
    }
</button>
