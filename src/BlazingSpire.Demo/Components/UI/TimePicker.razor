@namespace BlazingSpire.Demo.Components.UI
@inherits BlazingSpire.Demo.Components.Shared.BlazingSpireComponentBase

<Popover @bind-IsOpen="_isOpen">
    <PopoverTrigger>
        <Input Type="text"
               Value="@DisplayValue"
               Placeholder="@Placeholder"
               ReadOnly="true"
               Disabled="@Disabled"
               Class="@Class"
               @attributes="AdditionalAttributes">
            <Suffix>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </Suffix>
        </Input>
    </PopoverTrigger>
    <PopoverContent Class="w-auto p-4">
        <div class="space-y-3">
            <div class="text-sm font-medium text-center">Select Time</div>

            @* Hours *@
            <div>
                <div class="text-xs text-muted-foreground mb-1">Hour</div>
                <div class="grid grid-cols-4 gap-1">
                    @for (var h = 1; h <= 12; h++)
                    {
                        var hour = h;
                        <button type="button" class="@HourButtonClasses(hour)"
                                @onclick="() => SetHourAsync(hour)">
                            @hour
                        </button>
                    }
                </div>
            </div>

            @* Minutes *@
            <div>
                <div class="text-xs text-muted-foreground mb-1">Minute</div>
                <div class="grid grid-cols-4 gap-1">
                    @for (var m = 0; m < 60; m += (MinuteStep < 1 ? 1 : MinuteStep > 15 ? 15 : MinuteStep))
                    {
                        var minute = m;
                        <button type="button" class="@MinuteButtonClasses(minute)"
                                @onclick="() => SetMinuteAsync(minute)">
                            @minute.ToString("D2")
                        </button>
                    }
                </div>
            </div>

            @* AM/PM *@
            <div class="flex items-center justify-center gap-2">
                <button type="button" class="@PeriodButtonClasses(false)" @onclick="async () => { _isPM = false; await UpdateTimeAsync(); }">AM</button>
                <button type="button" class="@PeriodButtonClasses(true)" @onclick="async () => { _isPM = true; await UpdateTimeAsync(); }">PM</button>
            </div>
        </div>
    </PopoverContent>
</Popover>
