@namespace BlazingSpire.Demo.Components.UI
@inherits BlazingSpire.Demo.Components.Shared.ChildOf<BlazingSpire.Demo.Components.UI.SelectTrigger>

@if (!string.IsNullOrEmpty(ParentSelect?.SelectedText))
{
    <span class="@Classes" @attributes="AdditionalAttributes">@ParentSelect.SelectedText</span>
}
else
{
    <span class="text-muted-foreground @Classes" @attributes="AdditionalAttributes">@ParentSelect?.Placeholder</span>
}
