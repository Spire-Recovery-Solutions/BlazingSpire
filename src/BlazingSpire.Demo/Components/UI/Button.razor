@namespace BlazingSpire.Demo.Components.UI
@inherits BlazingSpire.Demo.Components.Shared.ButtonBase<ButtonVariant, ButtonSize>

@if (IsLink)
{
    <a href="@Href"
       target="@Target"
       rel="@Rel"
       class="@Classes"
       aria-disabled="@(IsEffectivelyDisabled ? "true" : null)"
       tabindex="@(IsEffectivelyDisabled ? -1 : (int?)null)"
       data-disabled="@(IsEffectivelyDisabled ? "" : null)"
       aria-busy="@(Loading ? "true" : null)"
       @attributes="AdditionalAttributes"
       @onclick="OnClick">
        @if (Loading)
        {
            <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
            </svg>
        }
        @ChildContent
    </a>
}
else
{
    <button class="@Classes"
            type="@Type"
            disabled="@IsEffectivelyDisabled"
            data-disabled="@(IsEffectivelyDisabled ? "" : null)"
            aria-busy="@(Loading ? "true" : null)"
            @attributes="AdditionalAttributes"
            @onclick="OnClick">
        @if (Loading)
        {
            <svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
            </svg>
        }
        @ChildContent
    </button>
}
