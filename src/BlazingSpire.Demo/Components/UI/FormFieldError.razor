@namespace BlazingSpire.Demo.Components.UI
@inherits BlazingSpire.Demo.Components.Shared.BlazingSpireComponentBase

@if (Field?.HasError == true)
{
    <p id="@Field.MessageId" role="alert" class="@Classes" @attributes="AdditionalAttributes">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @Field.ErrorMessage
        }
    </p>
}
