@namespace BlazingSpire.Demo.Components.UI
@inherits BlazingSpire.Demo.Components.Shared.NumericInputBase<T>
@typeparam T where T : struct, System.Numerics.INumber<T>, System.Numerics.IMinMaxValue<T>

@if (HasAdornments)
{
    <div class="@WrapperClasses">
        @if (ShowButtons)
        {
            <button type="button" class="@ButtonClasses border-r" disabled="@IsEffectivelyDisabled"
                    @onclick="DecrementAsync" aria-label="Decrease value" tabindex="-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3">
                    <path d="M5 12h14"/>
                </svg>
            </button>
        }
        @if (Prefix is not null)
        {
            <div class="flex items-center pl-3 text-muted-foreground">@Prefix</div>
        }
        <input type="number"
               value="@DisplayValue"
               placeholder="@Placeholder"
               disabled="@IsEffectivelyDisabled"
               readonly="@ReadOnly"
               required="@Required"
               name="@Name"
               min="@(Min?.ToString(null, System.Globalization.CultureInfo.InvariantCulture))"
               max="@(Max?.ToString(null, System.Globalization.CultureInfo.InvariantCulture))"
               step="@(Step?.ToString(null, System.Globalization.CultureInfo.InvariantCulture))"
               aria-invalid="@AriaInvalid"
               aria-describedby="@AriaDescribedBy"
               class="@InnerInputClasses"
               @onchange="OnChangeAsync"
               @attributes="AdditionalAttributes" />
        @if (Suffix is not null)
        {
            <div class="flex items-center pr-3 text-muted-foreground">@Suffix</div>
        }
        @if (ShowButtons)
        {
            <button type="button" class="@ButtonClasses border-l" disabled="@IsEffectivelyDisabled"
                    @onclick="IncrementAsync" aria-label="Increase value" tabindex="-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3">
                    <path d="M5 12h14"/><path d="M12 5v14"/>
                </svg>
            </button>
        }
    </div>
}
else
{
    <input type="number"
           value="@DisplayValue"
           placeholder="@Placeholder"
           disabled="@IsEffectivelyDisabled"
           readonly="@ReadOnly"
           required="@Required"
           name="@Name"
           min="@(Min?.ToString(null, System.Globalization.CultureInfo.InvariantCulture))"
           max="@(Max?.ToString(null, System.Globalization.CultureInfo.InvariantCulture))"
           step="@(Step?.ToString(null, System.Globalization.CultureInfo.InvariantCulture))"
           aria-invalid="@AriaInvalid"
           aria-describedby="@AriaDescribedBy"
           class="@Classes"
           @onchange="OnChangeAsync"
           @attributes="AdditionalAttributes" />
}
